---
// 建议后续将此数据移至 src/data/tools.ts
const categories = [
  {
    title: "Quotes & Pricing",
    description: "Create quotations, proforma invoices, and pricing calculations.",
    tools: [
      { name: "Quotation Generator", slug: "quotation-generator" },
      { name: "Proforma Invoice Generator", slug: "proforma-invoice-generator" },
      { name: "Profit Calculator", slug: "profit-calculator" },
      { name: "Margin Calculator", slug: "margin-calculator" },
    ],
    href: "/quotes-pricing/",
  },
  {
    title: "Invoices & Documents",
    description: "Generate clear business documents for clients and operations.",
    tools: [
      { name: "Receipt Generator", slug: "receipt-generator" },
      { name: "Delivery Note Generator", slug: "delivery-note-generator" },
      { name: "Commercial Invoice Generator", slug: "commercial-invoice-generator" },
      { name: "Purchase Order Generator", slug: "purchase-order-generator" },
    ],
    href: "/invoices-documents/",
  },
  {
    title: "Packing & Shipping",
    description: "Prepare packing lists and calculate shipping volume.",
    tools: [
      { name: "Packing List Generator", slug: "packing-list-generator" },
      { name: "Volumetric Weight Calculator", slug: "volumetric-weight-calculator" },
      { name: "How Many Fit Calculator", slug: "how-many-fit-calculator" },
      { name: "Carton Fill Rate Calculator", slug: "carton-fill-rate-calculator" },
    ],
    href: "/packing-shipping/",
  },
];

const featuredTools = [
  {
    name: "Quotation Generator",
    description: "Create clean quotations in minutes.",
    href: "/quotes-pricing/quotation-generator/",
  },
  {
    name: "Proforma Invoice Generator",
    description: "Generate simple proforma invoices.",
    href: "/quotes-pricing/proforma-invoice-generator/",
  },
  {
    name: "Packing List Generator",
    description: "Prepare packing lists for shipments.",
    href: "/packing-shipping/packing-list-generator/",
  },
  {
    name: "Profit Calculator",
    description: "Estimate product profit instantly.",
    href: "/quotes-pricing/profit-calculator/",
  },
  {
    name: "Margin Calculator",
    description: "Check margin quickly before quoting.",
    href: "/quotes-pricing/margin-calculator/",
  },
  {
    name: "Volumetric Weight Calculator",
    description: "Calculate chargeable weight.",
    href: "/packing-shipping/volumetric-weight-calculator/",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>worowo — Lightweight Business Tools for Quotes, Packing & Shipping</title>
    <meta
      name="description"
      content="Instant online tools for small sellers and exporters. Generate quotations, invoices, and packing lists without complex software."
    />
    <link rel="canonical" href="https://worowo.com/" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">worowo</a>
        <nav class="nav">
          <a href="#categories">Categories</a>
          <a href="#tools">Featured</a>
          <a href="#about">About</a>
          <a href="mailto:hello@worowo.com" class="nav-contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-inner">
          <p class="eyebrow">A Focused Toolkit for Exporters</p>
          <h1>Instant tools for business tasks</h1>
          <p class="hero-text">
            Create professional documents and precise calculations in seconds.
            <strong>No registration, no learning curve, just results.</strong>
          </p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="/quotes-pricing/quotation-generator/">
              Start Quotation Generator
            </a>
            <a class="btn btn-secondary" href="#categories">Browse Categories</a>
          </div>
        </div>
      </section>

      <section id="categories" class="section">
        <div class="container">
          <div class="section-heading align-left">
            <h2>Categories</h2>
            <p>Streamlined workflows for your daily business operations.</p>
          </div>

          <div class="category-grid">
            {categories.map((category) => (
              <article class="card category-card">
                <div class="card-header">
                  <h3>{category.title}</h3>
                  <p class="card-text">{category.description}</p>
                </div>

                <ul class="tool-list">
                  {category.tools.map((tool) => (
                    <li>
                      <a href={`${category.href}${tool.slug}/`} class="tool-link-inline">
                        {tool.name}
                      </a>
                    </li>
                  ))}
                </ul>

                <a class="action-link" href={category.href}>
                  Explore all tools →
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="tools" class="section section-soft">
        <div class="container">
          <div class="section-heading">
            <h2>Featured Tools</h2>
            <p>Most used tools by small business owners and sourcing agents.</p>
          </div>

          <div class="tool-grid">
            {featuredTools.map((tool) => (
              <a href={tool.href} class="card tool-card clickable">
                <h3>{tool.name}</h3>
                <p class="card-text">{tool.description}</p>
                <span class="btn-text">Open Tool</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="why-grid">
            <div class="benefit-item">
              <h4>No Setup Required</h4>
              <p>Work directly in your browser without installing anything.</p>
            </div>
            <div class="benefit-item">
              <h4>Print-Ready PDF</h4>
              <p>Outputs are perfectly formatted for professional delivery.</p>
            </div>
            <div class="benefit-item">
              <h4>Privacy First</h4>
              <p>Your data stays in your browser. We don't track your business details.</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-top">
          <span class="logo">worowo</span>
          <nav class="footer-links">
            <a href="#about">About</a>
            <a href="#privacy">Privacy</a>
            <a href="#terms">Terms</a>
          </nav>
        </div>
        <div class="footer-bottom">
          <p>© 2026 worowo. Built for efficiency.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --bg: #ffffff;
    --bg-soft: #f8fafc;
    --text: #0f172a;
    --text-soft: #64748b;
    --line: #e2e8f0;
    --card: #ffffff;
    --max: 1200px;
    --radius: 12px;
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: "Inter", system-ui, sans-serif;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    width: min(var(--max), calc(100% - 40px));
    margin: 0 auto;
  }

  .logo {
    font-family: "Roboto", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--text);
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 24px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav {
    display: flex;
    gap: 24px;
  }

  .nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-soft);
    transition: 0.2s;
  }

  .nav a:hover {
    color: var(--primary);
  }

  .hero {
    padding: 100px 0 80px;
  }

  .eyebrow {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }

  .hero-text {
    font-size: 1.25rem;
    color: var(--text-soft);
    max-width: 600px;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
    text-align: center;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
    border: 1px solid var(--primary);
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
  }

  .btn-secondary {
    border: 1px solid var(--line);
    color: var(--text);
  }

  .btn-secondary:hover {
    background: var(--bg-soft);
  }

  .section {
    padding: 80px 0;
  }

  .section-soft {
    background: var(--bg-soft);
  }

  .section-heading {
    margin-bottom: 48px;
  }

  .section-heading h2 {
    font-size: 2rem;
    letter-spacing: -0.02em;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 32px;
    transition: 0.3s;
    box-shadow: var(--shadow-sm);
  }

  .tool-card.clickable {
    display: block;
    text-decoration: none;
  }

  .tool-card.clickable:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .tool-list {
    list-style: none;
    padding: 0;
    margin: 24px 0;
  }

  .tool-list li {
    margin-bottom: 12px;
  }

  .tool-link-inline {
    font-size: 1rem;
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: 0.2s;
  }

  .tool-link-inline:hover {
    color: var(--primary);
    text-decoration-color: var(--primary);
  }

  .action-link {
    font-weight: 600;
    color: var(--primary);
    font-size: 0.9rem;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .benefit-item h4 {
    margin: 0 0 8px;
    font-size: 1rem;
  }

  .benefit-item p,
  .card-text {
    margin: 0;
    color: var(--text-soft);
  }

  .btn-text {
    display: inline-block;
    margin-top: 16px;
    font-weight: 600;
    color: var(--primary);
  }

  .site-footer {
    padding: 60px 0 40px;
    border-top: 1px solid var(--line);
    background: var(--bg-soft);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .footer-links {
    display: flex;
    gap: 24px;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .footer-bottom p {
    margin: 0;
    color: var(--text-soft);
  }

  @media (max-width: 768px) {
    .header-inner {
      height: auto;
      min-height: 72px;
      padding: 14px 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .nav {
      flex-wrap: wrap;
      gap: 12px 16px;
    }

    .hero {
      padding: 60px 0;
    }

    .hero-actions {
      flex-direction: column;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .footer-top {
      flex-direction: column;
      gap: 24px;
      text-align: center;
    }
  }
</style>
