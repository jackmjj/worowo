---
const toolGroups = [
  {
    title: "Quotes & Invoices",
    description:
      "Generate professional business documents in seconds — ready to send or print.",
    tools: [
      {
        name: "Quote / Estimate Generator",
        desc: "Create a clean price quote to send to a client",
        href: "/quotes-invoices/quote-generator/",
      },
      {
        name: "Invoice Generator",
        desc: "Generate a professional invoice, ready to send or print",
        href: "/quotes-invoices/invoice-generator/",
      },
      {
        name: "Proforma Invoice Generator",
        desc: "Issue a proforma before the sale is confirmed",
        href: "/quotes-invoices/proforma-invoice/",
      },
      {
        name: "Receipt Generator",
        desc: "Provide a simple proof of payment",
        href: "/quotes-invoices/receipt-generator/",
      },
    ],
  },
  {
    title: "Packing & Shipping",
    description:
      "Prepare packing documents and shipping paperwork without opening complex software.",
    tools: [
      {
        name: "Packing Slip Generator",
        desc: "List the items included in a shipment",
        href: "/packing-shipping/packing-slip/",
      },
      {
        name: "Packing List Generator",
        desc: "Detailed list for larger or multi-box shipments",
        href: "/packing-shipping/packing-list/",
      },
      {
        name: "Delivery Note Generator",
        desc: "Confirm what was delivered and when",
        href: "/packing-shipping/delivery-note/",
      },
    ],
  },
  {
    title: "Business Calculators",
    description:
      "Quick answers to the numbers that matter for pricing and daily operations.",
    tools: [
      {
        name: "Profit Margin Calculator",
        desc: "Find out exactly how much you're making per sale",
        href: "/calculators/margin-calculator/",
      },
      {
        name: "Markup Calculator",
        desc: "Set the right selling price from your cost",
        href: "/calculators/markup-calculator/",
      },
      {
        name: "Break-even Calculator",
        desc: "Know the minimum price to cover your costs",
        href: "/calculators/break-even/",
      },
      {
        name: "Landed Cost Calculator",
        desc: "Factor in shipping, tax, and fees into true cost",
        href: "/calculators/landed-cost/",
      },
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>worowo — Skip the Software. Get the Result.</title>
    <meta
      name="description"
      content="Generate invoices, quotes, packing documents, and business calculations in seconds. Ready to print or send. No account needed. No setup."
    />
    <link rel="canonical" href="https://www.worowo.com/" />
    <meta name="theme-color" content="#ffffff" />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">worowo</a>

        <nav class="nav" aria-label="Primary">
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
          <a href="#privacy">Privacy</a>
          <a href="#terms">Terms</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero-tools" id="top">
        <div class="container hero-tools-inner">
          <div class="hero-copy">
            <p class="eyebrow">Instant tools for business tasks</p>
            <h1>Skip the Software. Get the Result.</h1>
            <p class="hero-text">
              Generate invoices, quotes, packing documents, and business
              calculations — ready to print or send, in seconds.
            </p>
            <p class="hero-subtext">
              No account needed. No setup. Just the tool you came for.
            </p>
          </div>

          <section class="tools-panel" aria-labelledby="tools-heading">
            <div class="tools-heading-row">
              <h2 id="tools-heading">Tools</h2>
            </div>

            <div class="tool-groups">
              {toolGroups.map((group) => (
                <section class="tool-group">
                  <div class="tool-group-header">
                    <h3>{group.title}</h3>
                    <p>{group.description}</p>
                  </div>

                  <div class="tool-list">
                    {group.tools.map((tool) => (
                      <a href={tool.href} class="tool-item">
                        <div class="tool-info">
                          <span class="tool-name">{tool.name}</span>
                          <span class="tool-desc">{tool.desc}</span>
                        </div>
                        <span class="arrow" aria-hidden="true">→</span>
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </section>
        </div>
      </section>

      <section id="about" class="bottom-section section-soft">
        <div class="container narrow">
          <h2>About</h2>
          <p>
            worowo is a lightweight toolkit for everyday business tasks. It is
            built for people who want clean results fast — without opening
            complicated software, setting up accounts, or learning a full editor.
          </p>
          <p>
            The goal is simple: turn small but necessary business tasks into
            ready-to-use tools that are practical, fast, and easy to trust.
          </p>
        </div>
      </section>

      <section id="contact" class="bottom-section">
        <div class="container narrow">
          <h2>Contact</h2>
          <p>
            For feedback, partnership inquiries, or support, contact:
          </p>
          <p>
            <a href="mailto:hello@worowo.com" class="inline-link"
              >hello@worowo.com</a
            >
          </p>
        </div>
      </section>

      <section id="privacy" class="bottom-section section-soft">
        <div class="container narrow">
          <h2>Privacy</h2>
          <p>
            worowo aims to collect as little information as possible. When a
            tool works entirely in your browser, your data stays on your device.
          </p>
          <p>
            If a future tool requires server-side processing, only the minimum
            necessary information will be used to provide that function.
          </p>
        </div>
      </section>

      <section id="terms" class="bottom-section">
        <div class="container narrow">
          <h2>Terms</h2>
          <p>
            worowo provides practical tools for general business use. Users are
            responsible for reviewing generated results before sending,
            printing, or using them in real transactions.
          </p>
          <p>
            The tools are provided as-is, without guarantees of suitability for
            every legal, tax, logistics, or commercial requirement in every
            country or situation.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-brand">worowo</p>
        <p class="footer-text">
          Skip the Software. Get the Result.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --text: #0f172a;
    --text-soft: #64748b;
    --bg: #ffffff;
    --bg-soft: #f8fafc;
    --line: #e2e8f0;
    --accent: #2563eb;
    --max: 1200px;
    --radius: 18px;
    --font-stack: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      Roboto, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-stack);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(var(--max), calc(100% - 32px));
    margin: 0 auto;
  }

  .narrow {
    max-width: 780px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 850;
    letter-spacing: -0.05em;
    text-transform: lowercase;
    color: var(--text);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .nav a {
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--text-soft);
  }

  .nav a:hover,
  .inline-link:hover {
    color: var(--accent);
  }

  .hero-tools {
    padding: 28px 0 40px;
  }

  .hero-tools-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr);
    gap: 28px;
    align-items: start;
    min-height: calc(100vh - 64px - 28px);
  }

  .hero-copy {
    padding-top: 8px;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 16px;
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    font-weight: 900;
    max-width: 10ch;
  }

  .hero-text {
    margin: 0 0 12px;
    font-size: 1.08rem;
    color: var(--text-soft);
    max-width: 56ch;
  }

  .hero-subtext {
    margin: 0;
    font-size: 1rem;
    color: var(--text);
    font-weight: 600;
  }

  .tools-panel {
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 18px;
    background: var(--bg);
  }

  .tools-heading-row {
    margin-bottom: 8px;
  }

  .tools-heading-row h2 {
    margin: 0;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .tool-groups {
    display: grid;
    gap: 18px;
  }

  .tool-group {
    border-top: 1px solid var(--line);
    padding-top: 16px;
  }

  .tool-group:first-child {
    border-top: 0;
    padding-top: 8px;
  }

  .tool-group-header {
    margin-bottom: 10px;
  }

  .tool-group-header h3 {
    margin: 0 0 4px;
    font-size: 1.06rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .tool-group-header p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  .tool-list {
    display: flex;
    flex-direction: column;
  }

  .tool-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    transition: 0.18s ease;
  }

  .tool-item:last-child {
    border-bottom: 0;
  }

  .tool-item:hover {
    transform: translateX(3px);
  }

  .tool-item:hover .tool-name,
  .tool-item:hover .arrow {
    color: var(--accent);
  }

  .tool-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .tool-name {
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .tool-desc {
    font-size: 0.88rem;
    color: var(--text-soft);
    line-height: 1.35;
  }

  .arrow {
    font-size: 1.05rem;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .bottom-section {
    padding: 52px 0;
    scroll-margin-top: 84px;
  }

  .section-soft {
    background: var(--bg-soft);
  }

  .bottom-section h2 {
    margin: 0 0 14px;
    font-size: 1.55rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .bottom-section p {
    margin: 0 0 12px;
    color: var(--text-soft);
    font-size: 0.98rem;
  }

  .inline-link {
    color: var(--text);
    font-weight: 600;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    padding: 24px 0 34px;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer-brand {
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: lowercase;
  }

  .footer-text {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.94rem;
  }

  @media (max-width: 1024px) {
    .hero-tools-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-copy {
      padding-top: 0;
    }
  }

  @media (max-width: 640px) {
    .container {
      width: min(var(--max), calc(100% - 24px));
    }

    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      padding: 12px 0;
    }

    .nav {
      gap: 10px 14px;
    }

    .hero-tools {
      padding: 18px 0 28px;
    }

    h1 {
      max-width: none;
      font-size: clamp(2rem, 11vw, 3rem);
    }

    .hero-text {
      font-size: 1rem;
    }

    .hero-subtext {
      font-size: 0.96rem;
    }

    .tools-panel {
      padding: 14px;
      border-radius: 16px;
    }

    .tool-item {
      padding: 12px 0;
    }

    .tool-name {
      font-size: 0.96rem;
    }

    .tool-desc {
      font-size: 0.85rem;
    }

    .bottom-section {
      padding: 40px 0;
    }
  }
</style>
