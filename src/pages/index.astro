---
// worowo - Perfect Alignment Edition
const categories = [
  {
    title: "Quotes & Invoices",
    badge: "Document",
    description: "Professional docs in seconds — ready to send or print.",
    tools: [
      { name: "Quote / Estimate Generator", slug: "quote-generator" },
      { name: "Invoice Generator", slug: "invoice-generator" },
      { name: "Proforma Invoice Generator", slug: "proforma-invoice" },
      { name: "Receipt Generator", slug: "receipt-generator" },
    ],
    href: "/quotes-invoices/",
  },
  {
    title: "Packing & Shipping",
    badge: "Logistics",
    description: "Shipping paperwork without opening complex software.",
    tools: [
      { name: "Packing Slip Generator", slug: "packing-slip" },
      { name: "Packing List Generator", slug: "packing-list" },
      { name: "Delivery Note Generator", slug: "delivery-note" },
    ],
    href: "/packing-shipping/",
  },
  {
    title: "Business Calculators",
    badge: "Finance",
    description: "Quick answers to the numbers that matter.",
    tools: [
      { name: "Profit Margin Calculator", slug: "margin-calculator" },
      { name: "Markup Calculator", slug: "markup-calculator" },
      { name: "Break-even Calculator", slug: "break-even" },
      { name: "Landed Cost Calculator", slug: "landed-cost" },
    ],
    href: "/calculators/",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>worowo — Skip the Software. Get the Result.</title>
    <meta
      name="description"
      content="Instant business tools: invoices, quotes, packing documents, and business calculations in seconds."
    />
    <link rel="canonical" href="https://www.worowo.com/" />
    <meta name="theme-color" content="#ffffff" />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">worowo</a>
        <nav class="nav">
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
          <a href="#privacy">Privacy</a>
          <a href="#terms">Terms</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-inner">
          <p class="eyebrow">Instant tools for business tasks</p>
          <h1>Skip the Software. <br />Get the Result.</h1>
          <p class="hero-text">
            Generate invoices, quotes, packing documents, and business calculations
            in seconds. <strong>No account, no setup, just results.</strong>
          </p>

          <div class="hero-actions">
            <a href="/calculators/margin-calculator/" class="hero-btn">
              Try Profit Margin Calculator
            </a>
          </div>
        </div>
      </section>

      <section id="tools" class="section">
        <div class="container">
          <div class="category-grid">
            {categories.map((category) => (
              <div class="category-card">
                <div class="card-inner">
                  <header class="card-header">
                    <span class="badge">{category.badge}</span>
                    <h2>{category.title}</h2>
                    <p>{category.description}</p>
                  </header>

                  <div class="tool-list">
                    {category.tools.map((tool) => (
                      <a href={`${category.href}${tool.slug}/`} class="tool-row">
                        <span class="tool-name">{tool.name}</span>
                        <span class="arrow">→</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="bottom-section section-soft" id="about">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>About</h2>
          </div>
          <p class="bottom-text">
            worowo is a lightweight toolkit for everyday business tasks. It is
            built for people who want clean results fast — without opening
            complicated software, creating an account, or learning a full editor.
          </p>
          <p class="bottom-text">
            The goal is simple: turn small but necessary business tasks into tools
            that are practical, fast, and ready to use.
          </p>
        </div>
      </section>

      <section class="bottom-section" id="contact">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>Contact</h2>
          </div>
          <p class="bottom-text">
            For feedback, support, or partnership inquiries, contact:
          </p>
          <p class="bottom-text">
            <a href="mailto:hello@worowo.com" class="inline-link">hello@worowo.com</a>
          </p>
        </div>
      </section>

      <section class="bottom-section section-soft" id="privacy">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>Privacy</h2>
          </div>
          <p class="bottom-text">
            worowo aims to collect as little information as possible. When a tool
            works entirely in your browser, your data stays on your device.
          </p>
          <p class="bottom-text">
            If a future tool requires server-side processing, only the minimum
            necessary information will be used to provide that function.
          </p>
        </div>
      </section>

      <section class="bottom-section" id="terms">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>Terms</h2>
          </div>
          <p class="bottom-text">
            worowo provides practical tools for general business use. Users are
            responsible for reviewing generated results before sending, printing,
            or using them in real transactions.
          </p>
          <p class="bottom-text">
            The tools are provided as-is, without guarantees of suitability for
            every legal, tax, logistics, or commercial requirement in every
            country or situation.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="logo">worowo</span>
        <p class="copyright">
          © 2026 worowo. Skip the Software. Get the Result.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --text: #0f172a;
    --text-soft: #64748b;
    --bg: #ffffff;
    --bg-soft: #f8fafc;
    --line: #e2e8f0;
    --font-stack: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-stack);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    width: min(1140px, calc(100% - 60px));
    margin: 0 auto;
  }

  .narrow {
    max-width: 800px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Header */
  .site-header {
    height: 72px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    z-index: 100;
  }

  .header-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .logo {
    font-size: 1.35rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    text-transform: lowercase;
    text-decoration: none;
    color: var(--text);
    display: block;
  }

  .nav {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-soft);
    text-decoration: none;
  }

  .nav a:hover,
  .inline-link:hover {
    color: var(--primary);
  }

  /* Hero */
  .hero {
    padding: 80px 0 60px;
  }

  .eyebrow {
    color: var(--primary);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(2.5rem, 6.5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    font-weight: 900;
  }

  .hero-text {
    font-size: 1.25rem;
    color: var(--text-soft);
    max-width: 680px;
    margin: 0;
  }

  .hero-text strong {
    color: var(--text);
  }

  .hero-actions {
    margin-top: 24px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    background: #2563eb;
    color: #ffffff;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: 0.2s ease;
    box-shadow: 0 6px 18px -10px rgba(37, 99, 235, 0.55);
  }

  .hero-btn:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  /* Main tools section */
  .section {
    padding-bottom: 100px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .category-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
    transition: 0.2s;
  }

  .category-card:hover {
    border-color: var(--text);
    box-shadow: 0 10px 30px -15px rgba(0, 0, 0, 0.08);
  }

  .card-inner {
    padding: 32px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--text-soft);
    background: var(--bg-soft);
    padding: 3px 8px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .card-header h2 {
    font-size: 1.6rem;
    font-weight: 850;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .card-header p {
    color: var(--text-soft);
    margin: 0 0 24px;
    font-size: 1rem;
    line-height: 1.4;
  }

  .tool-list {
    border-top: 2px solid var(--text);
    margin-bottom: 0;
  }

  .tool-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px dotted var(--line);
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-size: 1rem;
  }

  .tool-row:hover {
    color: var(--primary);
    border-bottom-style: solid;
    border-bottom-color: var(--text);
  }

  .tool-row .arrow {
    color: var(--line);
    transition: 0.2s;
    font-weight: 300;
  }

  .tool-row:hover .arrow {
    transform: translateX(4px);
    color: var(--text);
  }

  /* Bottom sections */
  .bottom-section {
    padding: 56px 0;
    scroll-margin-top: 84px;
  }

  .section-soft {
    background: var(--bg-soft);
  }

  .bottom-heading {
    margin-bottom: 16px;
  }

  .bottom-heading h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .bottom-text {
    font-size: 1rem;
    color: var(--text-soft);
    margin: 0 0 12px;
  }

  .inline-link {
    color: var(--text);
    font-weight: 600;
  }

  /* Footer */
  .site-footer {
    padding: 36px 0 40px;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--text-soft);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .category-grid {
      grid-template-columns: 1fr;
    }

    .container {
      width: calc(100% - 40px);
    }
  }

  @media (max-width: 768px) {
    .site-header {
      height: auto;
    }

    .header-inner {
      padding: 14px 0;
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .nav {
      gap: 12px 16px;
    }

    .hero {
      padding: 60px 0 40px;
    }
  }

  @media (max-width: 600px) {
    .container {
      width: calc(100% - 24px);
    }

    h1 {
      font-size: 2.2rem;
    }

    .hero-text {
      font-size: 1.06rem;
    }

    .hero-actions {
      margin-top: 20px;
    }

    .hero-btn {
      width: 100%;
    }

    .card-inner {
      padding: 24px;
    }

    .bottom-section {
      padding: 40px 0;
    }
  }
</style>