---
import BaseLayout from "../layouts/BaseLayout.astro";

const categories = [
  {
    title: "Quotes & Invoices",
    badge: "Documents",
    description: "Professional docs in seconds — ready to send or print.",
    href: "/quotes-invoices/",
    moreLabel: "More quotes & invoice tools",
    tools: [
      {
        name: "Quote / Estimate Generator",
        desc: "Create a clean price quote to send to a client",
        status: "Coming soon",
      },
      {
        name: "Invoice Generator",
        desc: "Generate a professional invoice, ready to send or print",
        status: "Coming soon",
      },
      {
        name: "Proforma Invoice Generator",
        desc: "Issue a proforma before the sale is confirmed",
        status: "Coming soon",
      },
      {
        name: "Receipt Generator",
        desc: "Provide a simple proof of payment",
        status: "Coming soon",
      },
    ],
  },
  {
    title: "Packing & Shipping",
    badge: "Shipping",
    description: "Shipping paperwork without opening complex software.",
    href: "/packing-shipping/",
    moreLabel: "More packing & shipping tools",
    tools: [
      {
        name: "Packing Slip Generator",
        desc: "List the items included in a shipment",
        status: "Coming soon",
      },
      {
        name: "Packing List Generator",
        desc: "Detailed list for larger or multi-box shipments",
        status: "Coming soon",
      },
      {
        name: "Delivery Note Generator",
        desc: "Confirm what was delivered and when",
        status: "Coming soon",
      },
      {
        name: "Commercial Invoice Generator",
        desc: "Future tool placeholder for shipping-related paperwork",
        status: "Coming soon",
      },
    ],
  },
  {
    title: "Business Calculators",
    badge: "Calculators",
    description: "Fast calculators for profit margin, markup, break-even pricing, and landed cost.",
    href: "/calculators/",
    moreLabel: "More business calculators",
    tools: [
      {
        name: "Profit Margin Calculator",
        desc: "See how much profit you actually keep from each sale",
        status: "Coming soon",
      },
      {
        name: "Markup Calculator",
        desc: "Set your selling price from your cost",
        status: "Coming soon",
      },
      {
        name: "Break-even Calculator",
        desc: "Find the minimum price needed to cover your costs",
        status: "Coming soon",
      },
      {
        name: "Landed Cost Calculator",
        desc: "Include shipping, tax, and fees in your true unit cost",
        status: "Coming soon",
      },
    ],
  },
  {
    title: "Printable Templates",
    badge: "Templates",
    description: "Download and print — no editing required.",
    href: "/templates/",
    moreLabel: "More printable templates",
    tools: [
      {
        name: "Blank Invoice Template",
        desc: "A clean, ready-to-print invoice sheet",
        status: "Coming soon",
      },
      {
        name: "Packing List Template",
        desc: "Pre-formatted packing list for manual use",
        status: "Coming soon",
      },
      {
        name: "Checklist / Duty Roster",
        desc: "Simple printable checklists for daily operations",
        status: "Coming soon",
      },
      {
        name: "Printable Receipt Template",
        desc: "Future template placeholder",
        status: "Coming soon",
      },
    ],
  },
];
---

<BaseLayout
  title="worowo — Invoice, Quote, Packing List, Template, and Business Calculator Tools"
  description="Free online tools for invoices, quotes, packing lists, printable templates, and business calculators. Create documents faster and calculate profit margins, markup, break-even pricing, and landed costs without complex software."
  canonical="https://www.worowo.com/"
>
  <main>
    <section class="section-tight">
      <div class="container">
        <div class="topline">
          <a href="/" class="logo">worowo</a>
        </div>

        <div class="hero-copy">
          <p class="brand-line">Skip the Software. Get the Result.</p>
          <h1 class="hero-title">Invoice, Quote, Packing List, Template, and Business Calculator Tools</h1>
          <p class="hero-summary">
            Create invoices, quotes, packing documents, printable templates, and pricing calculations in seconds. No account, no setup, just results.
          </p>

          <div class="hero-actions">
            <a href="#tools" class="hero-btn">Browse Tools</a>
          </div>
        </div>
      </div>
    </section>

    <section id="tools" class="section-tight">
      <div class="container">
        <div class="category-grid">
          {categories.map((category) => (
            <article class="category-card">
              <div class="card-inner">
                <header class="card-header">
                  <span class="badge">{category.badge}</span>
                  <h2>
                    <a href={category.href} class="category-link">{category.title}</a>
                  </h2>
                  <p>{category.description}</p>
                </header>

                <div class="tool-list">
                  {category.tools.map((tool) => (
                    <div class="tool-row tool-row-static">
                      <div class="tool-meta">
                        <div>
                        <span class="tool-name">{tool.name}</span>
                        <span class="tool-desc">{tool.desc}</span>
                        </div>
                        <span class="tool-status">{tool.status}</span>
                      </div>
                      <span class="arrow">→</span>
                    </div>
                  ))}
                </div>

                <a href={category.href} class="more-link">{category.moreLabel}</a>
              </div>
            </article>
          ))}
        </div>

        <p class="seo-copy">
          worowo provides free online tools for invoices, quotes, packing lists, printable templates, and business calculators. Create documents faster, calculate profit margins and landed costs, and prepare shipping paperwork without opening complex software. Each tool is designed to be simple, fast, and ready to print or send.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
