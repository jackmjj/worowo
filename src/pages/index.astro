---
const categories = [
  {
    title: "Quotes & Pricing",
    description:
      "Create quotations, proforma invoices, and pricing calculations for faster decisions.",
    tools: [
      "Quotation Generator",
      "Proforma Invoice Generator",
      "Profit Calculator",
      "Margin Calculator",
    ],
    href: "/quotes-pricing/",
  },
  {
    title: "Invoices & Documents",
    description:
      "Generate clear, ready-to-use business documents for clients, records, and daily operations.",
    tools: [
      "Receipt Generator",
      "Delivery Note Generator",
      "Commercial Invoice Generator",
      "Purchase Order Generator",
    ],
    href: "/invoices-documents/",
  },
  {
    title: "Packing & Shipping",
    description:
      "Prepare packing lists and shipping calculations for cartons, volume, and fulfillment.",
    tools: [
      "Packing List Generator",
      "Volumetric Weight Calculator",
      "How Many Fit Calculator",
      "Carton Fill Rate Calculator",
    ],
    href: "/packing-shipping/",
  },
];

const featuredTools = [
  {
    name: "Quotation Generator",
    description: "Create clean quotations in minutes.",
    href: "/quotes-pricing/quotation-generator/",
  },
  {
    name: "Proforma Invoice Generator",
    description: "Generate simple proforma invoices for customer confirmation.",
    href: "/quotes-pricing/proforma-invoice-generator/",
  },
  {
    name: "Packing List Generator",
    description: "Prepare packing lists for shipments and cartons.",
    href: "/packing-shipping/packing-list-generator/",
  },
  {
    name: "Profit Calculator",
    description: "Estimate product profit with simple inputs.",
    href: "/quotes-pricing/profit-calculator/",
  },
  {
    name: "Margin Calculator",
    description: "Check margin quickly before you quote.",
    href: "/quotes-pricing/margin-calculator/",
  },
  {
    name: "Volumetric Weight Calculator",
    description: "Calculate chargeable shipping weight instantly.",
    href: "/packing-shipping/volumetric-weight-calculator/",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>worowo — Lightweight business tools</title>
    <meta
      name="description"
      content="Lightweight business tools for quotes, documents, packing, and shipping."
    />
    <meta name="theme-color" content="#ffffff" />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">worowo</a>

        <nav class="nav">
          <a href="#categories">Categories</a>
          <a href="#tools">Tools</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-inner">
          <p class="eyebrow">Lightweight business tools</p>
          <h1>Instant tools for quotes, documents, packing, and shipping</h1>
          <p class="hero-text">
            Create clean business documents and simple calculations without opening
            complex software. Fast, practical, and ready to use.
          </p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="#categories">Browse Tools</a>
            <a class="btn btn-secondary" href="/quotes-pricing/quotation-generator/">
              Start with Quotation Generator
            </a>
          </div>
        </div>
      </section>

      <section id="categories" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>Categories</h2>
            <p>
              Built around real business tasks, not around complex software.
            </p>
          </div>

          <div class="category-grid">
            {categories.map((category) => (
              <article class="card category-card">
                <h3>{category.title}</h3>
                <p class="card-text">{category.description}</p>

                <ul class="tool-list">
                  {category.tools.map((tool) => <li>{tool}</li>)}
                </ul>

                <a class="text-link" href={category.href}>
                  View category
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="tools" class="section section-soft">
        <div class="container">
          <div class="section-heading">
            <h2>Featured tools</h2>
            <p>Start with a few focused tools that solve practical business tasks.</p>
          </div>

          <div class="tool-grid">
            {featuredTools.map((tool) => (
              <article class="card tool-card">
                <h3>{tool.name}</h3>
                <p class="card-text">{tool.description}</p>
                <a class="text-link" href={tool.href}>Open tool</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="section-heading">
            <h2>Why worowo</h2>
          </div>

          <div class="why-grid">
            <article class="card small-card">
              <h3>No complex setup</h3>
              <p class="card-text">
                Use the tool directly without installing software or learning a full editor.
              </p>
            </article>

            <article class="card small-card">
              <h3>Ready-to-use results</h3>
              <p class="card-text">
                Generate outputs that are easy to print, download, or send.
              </p>
            </article>

            <article class="card small-card">
              <h3>Built for practical tasks</h3>
              <p class="card-text">
                Focused on lightweight business actions, not bloated workflows.
              </p>
            </article>

            <article class="card small-card">
              <h3>Clean and quiet</h3>
              <p class="card-text">
                A simple interface designed to reduce friction and get the job done.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="about" class="section section-soft">
        <div class="container narrow">
          <div class="section-heading align-left">
            <h2>About</h2>
          </div>
          <p class="content-text">
            worowo is a focused toolkit for lightweight business tasks around quoting,
            documents, packing, and shipping. It is designed for people who want quick,
            clear results without opening complex software.
          </p>
        </div>
      </section>

      <section id="contact" class="section">
        <div class="container narrow">
          <div class="section-heading align-left">
            <h2>Contact</h2>
          </div>
          <p class="content-text">
            For feedback, partnership inquiries, or support, contact:
          </p>
          <p class="content-text">
            <a class="text-link" href="mailto:hello@worowo.com">hello@worowo.com</a>
          </p>
        </div>
      </section>

      <section id="privacy" class="section section-soft">
        <div class="container narrow">
          <div class="section-heading align-left">
            <h2>Privacy Policy</h2>
          </div>
          <p class="content-text">
            worowo aims to collect as little personal information as possible.
            When a tool works entirely in your browser, your data stays on your device.
          </p>
          <p class="content-text">
            If a future tool requires server-side processing, only the minimum necessary
            information will be processed to provide that function. We do not aim to build
            intrusive tracking or unnecessary data collection into the product.
          </p>
        </div>
      </section>

      <section id="terms" class="section">
        <div class="container narrow">
          <div class="section-heading align-left">
            <h2>Terms</h2>
          </div>
          <p class="content-text">
            worowo provides practical tools for general business use. Users are responsible
            for reviewing generated results before sending, printing, or using them in real
            transactions.
          </p>
          <p class="content-text">
            The tools are provided as-is, without guarantees of suitability for every legal,
            tax, logistics, or commercial requirement in every country or situation.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-brand">worowo</p>
        <p class="footer-text">
          Lightweight tools for quotes, documents, packing, and shipping.
        </p>
        <div class="footer-links">
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
          <a href="#privacy">Privacy</a>
          <a href="#terms">Terms</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #ffffff;
    --bg-soft: #f7f7f5;
    --text: #121212;
    --text-soft: #5f5f5a;
    --line: #e7e7e2;
    --card: #ffffff;
    --max: 1120px;
    --radius: 18px;
    --shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(var(--max), calc(100% - 32px));
    margin: 0 auto;
  }

  .narrow {
    max-width: 760px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(231, 231, 226, 0.8);
  }

  .header-inner {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .logo {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .nav a {
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  .nav a:hover,
  .text-link:hover {
    color: var(--text);
  }

  .hero {
    padding: 72px 0 48px;
  }

  .hero-inner {
    max-width: 860px;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 6vw, 4.2rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    max-width: 12ch;
  }

  .hero-text {
    margin: 20px 0 0;
    max-width: 680px;
    font-size: 1.05rem;
    color: var(--text-soft);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: 0.2s ease;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--text);
    color: #fff;
  }

  .btn-primary:hover {
    opacity: 0.92;
  }

  .btn-secondary {
    background: transparent;
    border-color: var(--line);
    color: var(--text);
  }

  .btn-secondary:hover {
    background: var(--bg-soft);
  }

  .section {
    padding: 52px 0;
  }

  .section-soft {
    background: var(--bg-soft);
  }

  .section-heading {
    margin-bottom: 22px;
    text-align: center;
  }

  .section-heading.align-left {
    text-align: left;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .section-heading p {
    margin: 10px 0 0;
    color: var(--text-soft);
    font-size: 1rem;
  }

  .category-grid,
  .tool-grid,
  .why-grid {
    display: grid;
    gap: 16px;
  }

  .category-grid,
  .tool-grid {
    grid-template-columns: 1fr;
  }

  .why-grid {
    grid-template-columns: 1fr;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px;
    box-shadow: var(--shadow);
  }

  .card h3 {
    margin: 0 0 10px;
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .card-text,
  .content-text {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.98rem;
  }

  .tool-list {
    margin: 14px 0 16px;
    padding-left: 18px;
    color: var(--text-soft);
  }

  .tool-list li + li {
    margin-top: 6px;
  }

  .text-link {
    display: inline-block;
    margin-top: 14px;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    padding: 28px 0 36px;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-brand {
    margin: 0;
    font-weight: 700;
  }

  .footer-text {
    margin: 0;
    color: var(--text-soft);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 4px;
  }

  .footer-links a {
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  @media (min-width: 720px) {
    .hero {
      padding: 96px 0 64px;
    }

    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1040px) {
    .tool-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .header-inner {
      align-items: flex-start;
      padding: 14px 0;
      flex-direction: column;
    }

    .nav {
      gap: 12px 16px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      width: 100%;
    }
  }
</style>
