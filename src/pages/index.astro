---
import BaseLayout from "../layouts/BaseLayout.astro";

const categories = [
  {
    title: "Quotes & Invoices",
    badge: "Documents",
    description: "Professional docs in seconds — ready to send or print.",
    href: "/quotes-invoices/",
    moreLabel: "More quotes & invoice tools",
    tools: [
      {
        name: "Quote / Estimate Generator",
        desc: "Create a clean price quote to send to a client",
        status: "Coming soon",
      },
      {
        name: "Invoice Generator",
        desc: "Generate a professional invoice, ready to send or print",
        status: "Coming soon",
      },
      {
        name: "Proforma Invoice Generator",
        desc: "Issue a proforma before the sale is confirmed",
        status: "Coming soon",
      },
      {
        name: "Receipt Generator",
        desc: "Provide a simple proof of payment",
        status: "Coming soon",
      },
    ],
  },
  {
    title: "Packing & Shipping",
    badge: "Shipping",
    description: "Shipping paperwork without opening complex software.",
    href: "/packing-shipping/",
    moreLabel: "More packing & shipping tools",
    tools: [
      {
        name: "Packing Slip Generator",
        desc: "List the items included in a shipment",
        status: "Coming soon",
      },
      {
        name: "Packing List Generator",
        desc: "Detailed list for larger or multi-box shipments",
        status: "Coming soon",
      },
      {
        name: "Delivery Note Generator",
        desc: "Confirm what was delivered and when",
        status: "Coming soon",
      },
      {
        name: "Commercial Invoice Generator",
        desc: "Future tool placeholder for shipping-related paperwork",
        status: "Coming soon",
      },
    ],
  },
  {
    title: "Business Calculators",
    badge: "Calculators",
    description: "Fast calculators for profit margin, markup, break-even pricing, and landed cost.",
    href: "/calculators/",
    moreLabel: "More business calculators",
    tools: [
      {
        name: "Profit Margin Calculator",
        desc: "See how much profit you actually keep from each sale",
        href: "/calculators/profit-margin-calculator/",
      },
      {
        name: "Markup Calculator",
        desc: "Set your selling price from your cost",
        status: "Coming soon",
      },
      {
        name: "Break-even Calculator",
        desc: "Find the minimum price needed to cover your costs",
        status: "Coming soon",
      },
      {
        name: "Landed Cost Calculator",
        desc: "Include shipping, tax, and fees in your true unit cost",
        status: "Coming soon",
      },
    ],
  },
  {
    title: "Printable Templates",
    badge: "Templates",
    description: "Download and print — no editing required.",
    href: "/printable-templates/",
    moreLabel: "More printable templates",
    tools: [
      {
        name: "Blank Invoice Template",
        desc: "A clean, ready-to-print invoice sheet",
        status: "Coming soon",
      },
      {
        name: "Simple Packing List Template",
        desc: "Clean A4 printable packing list for shipping and export paperwork",
        href: "/printable-templates/simple-packing-list-template/",
      },
      {
        name: "Checklist / Duty Roster",
        desc: "Simple printable checklists for daily operations",
        status: "Coming soon",
      },
      {
        name: "Printable Receipt Template",
        desc: "Future template placeholder",
        status: "Coming soon",
      },
    ],
  },
];
---

<BaseLayout
  title="worowo — Invoice, Quote, Packing List, Template, and Business Calculator Tools"
  description="Free online tools for invoices, quotes, packing lists, printable templates, and business calculators. Create documents faster and calculate profit margins, markup, break-even pricing, and landed costs without complex software."
  canonical="https://www.worowo.com/"
>
  <main>
    <section class="section-tight home-hero">
      <div class="container">
        <div class="hero-copy">
          <p class="brand-line">Skip the Software. Get the Result.</p>
          <h1 class="hero-title">Invoice, Quote, Packing List, Template, and Business Calculator Tools</h1>
          <p class="hero-summary">
            Create invoices, quotes, packing documents, printable templates, and pricing calculations in seconds. No account, no setup, just results.
          </p>

          <div class="hero-actions">
            <a href="#tools" class="hero-btn">Browse Tools</a>
          </div>
        </div>
      </div>
    </section>

    <section id="tools" class="section-tight">
      <div class="container">
        <div class="category-grid">
          {categories.map((category) => (
            <article class="category-card">
              <div class="card-inner">
                <header class="card-header">
                  <div class="card-title-row">
                    <h2>
                      <a href={category.href} class="category-link">{category.title}</a>
                    </h2>
                    <span class="badge">{category.badge}</span>
                  </div>
                  <p>{category.description}</p>
                </header>

                <div class="tool-list">
                  {category.tools.map((tool) =>
                    tool.href ? (
                      <a href={tool.href} class="tool-row">
                        <div class="tool-meta">
                          <div>
                            <span class="tool-name">{tool.name}</span>
                            <span class="tool-desc">{tool.desc}</span>
                          </div>
                        </div>
                        <span class="arrow">→</span>
                      </a>
                    ) : (
                      <div class="tool-row tool-row-static">
                        <div class="tool-meta">
                          <div>
                            <span class="tool-name">{tool.name}</span>
                            <span class="tool-desc">{tool.desc}</span>
                          </div>
                          <span class="tool-status">{tool.status}</span>
                        </div>
                        <span class="arrow">→</span>
                      </div>
                    )
                  )}
                </div>

                <a href={category.href} class="more-link">{category.moreLabel}</a>
              </div>
            </article>
          ))}
        </div>

        <section class="seo-statement">
          <div class="statement-inner">
            <p>
              <strong>worowo</strong> provides free online tools for invoices, quotes, packing lists, printable templates, and business calculators.
              Create documents faster, calculate profit margins and landed costs, and prepare shipping paperwork without opening complex software.
              Each tool is designed to be simple, fast, and ready to print or send.
            </p>
          </div>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-hero {
    padding-top: 22px;
  }

  .section-tight {
    padding: 0 0 72px;
  }

  .hero-copy {
    max-width: 780px;
  }

  .brand-line {
    margin: 0 0 12px;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #2563eb;
  }

  .hero-title {
    margin: 0 0 18px;
    font-size: clamp(2.3rem, 6vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    font-weight: 900;
  }

  .hero-summary {
    margin: 0;
    font-size: 1.12rem;
    color: var(--text-soft);
    max-width: 760px;
  }

  .hero-actions {
    margin-top: 22px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    background: var(--primary);
    color: #fff;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 700;
    transition: 0.2s ease;
    box-shadow: 0 8px 22px -12px rgba(37, 99, 235, 0.55);
  }

  .hero-btn:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
  }

  .category-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
    transition: 0.2s ease;
  }

  .category-card:hover {
    border-color: var(--text);
    box-shadow: 0 10px 30px -15px rgba(0, 0, 0, 0.08);
  }

  .card-inner {
    padding: 22px 28px 28px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-header p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.75;
  }

  .card-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .card-title-row h2 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .category-link:hover {
    color: var(--primary);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--bg-soft);
    color: rgba(100, 116, 139, 0.82);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tool-list {
    display: grid;
    gap: 0;
    margin: 22px 0 18px;
    border-top: 1px solid var(--line);
  }

  .tool-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
    transition: color 0.2s ease;
  }

  .tool-row:hover {
    color: var(--primary);
  }

  .tool-row-static {
    color: inherit;
  }

  .tool-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .tool-name {
    display: block;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .tool-desc {
    display: block;
    margin-top: 4px;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .tool-status {
    flex-shrink: 0;
    color: var(--text-soft);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .arrow {
    flex-shrink: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary);
  }

  .more-link {
    display: inline-flex;
    align-items: center;
    margin-top: auto;
    padding-top: 2px;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--primary);
  }

  .more-link:hover {
    color: #1d4ed8;
  }

  .seo-statement {
    padding: 60px 0 20px;
  }

  .statement-inner {
    border-left: 3px solid var(--text);
    padding-left: 32px;
    max-width: 850px;
  }

  .statement-inner p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-soft);
    margin: 0;
  }

  .statement-inner strong {
    color: var(--text);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .home-hero {
      padding-top: 18px;
    }

    .hero-title {
      font-size: 2.3rem;
    }

    .hero-summary {
      font-size: 1rem;
    }

    .hero-btn {
      width: 100%;
    }

    .card-inner {
      padding: 20px;
    }

    .card-title-row {
      align-items: flex-start;
    }

    .tool-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .statement-inner {
      padding-left: 20px;
    }

    .statement-inner p {
      font-size: 1rem;
    }
  }
</style>
