---
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeCategories } from "../data/homeCategories";
---

<BaseLayout
  title="worowo — Invoice, Quote, Packing List, Template, and Business Calculator Tools"
  description="Free online tools for invoices, quotes, packing lists, printable templates, and business calculators. Create documents faster and calculate profit margins, markup, break-even pricing, and landed costs without complex software."
  canonical="https://www.worowo.com/"
>
  <main>
    <section class="section-tight home-hero">
      <div class="container">
        <div class="hero-copy">
          <p class="brand-line">Skip the Software. Get the Result.</p>
          <h1 class="hero-title">Invoice, Quote, Packing List, Template, and Business Calculator Tools</h1>
          <p class="hero-summary">
            Create invoices, quotes, packing documents, printable templates, and pricing calculations in seconds. No account, no setup, just results.
          </p>

          <div class="hero-actions">
            <a href="#tools" class="hero-btn">Browse Tools</a>
          </div>
        </div>
      </div>
    </section>

    <section id="tools" class="section-tight">
      <div class="container">
        <div class="category-grid">
          {homeCategories.map((category) => (
            <article
              class="category-card"
              style={`--category:${category.theme.solid};--category-soft:${category.theme.soft};--category-soft-border:${category.theme.softBorder};--category-badge:${category.theme.badgeBg};--category-badge-text:${category.theme.badgeText};--category-glow:${category.theme.glow};`}
            >
              <div class="card-inner">
                <header class="card-header">
                  <div class="category-header-main">
                    <div class="category-icon-wrap">
                      <span class="category-icon" set:html={category.icon}></span>
                    </div>

                    <div class="category-copy">
                      <div class="card-title-row">
                        <h2>
                          <a href={category.href} class="category-link">{category.title}</a>
                        </h2>
                      </div>
                      <div class="card-meta-row">
                        <p>{category.description}</p>
                        <span class="badge">{category.badge}</span>
                      </div>
                    </div>
                  </div>
                </header>

                <div class="tool-list">
                  {category.tools.map((tool) =>
                    tool.href ? (
                      <a href={tool.href} class="tool-row">
                        <div class="tool-leading">
                          <span class="tool-icon" set:html={tool.icon}></span>
                          <div class="tool-copy">
                            <span class="tool-name">{tool.name}</span>
                            <span class="tool-desc">{tool.desc}</span>
                          </div>
                        </div>
                        <div class="tool-trailing">
                          <span class="arrow">→</span>
                        </div>
                      </a>
                    ) : (
                      <div class="tool-row tool-row-static">
                        <div class="tool-leading">
                          <span class="tool-icon" set:html={tool.icon}></span>
                          <div class="tool-copy">
                            <span class="tool-name">{tool.name}</span>
                            <span class="tool-desc">{tool.desc}</span>
                          </div>
                        </div>
                        <div class="tool-trailing">
                          <span class="tool-status">{tool.status}</span>
                          <span class="arrow arrow-muted">→</span>
                        </div>
                      </div>
                    )
                  )}
                </div>

                <a href={category.href} class="more-link">
                  <span class="more-icon" set:html={category.moreIcon}></span>
                  <span>{category.moreLabel}</span>
                  <span class="more-arrow">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        <section class="seo-statement">
          <div class="statement-inner">
            <p>
              <strong>worowo</strong> provides free online tools for invoices, quotes, packing lists, printable templates, and business calculators.
              Create documents faster, calculate profit margins and landed costs, and prepare shipping paperwork without opening complex software.
              Each tool is designed to be simple, fast, and ready to print or send.
            </p>
          </div>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-hero {
    padding-top: 22px;
  }

  .section-tight {
    padding: 0 0 72px;
  }

  .hero-copy {
    max-width: 780px;
  }

  .brand-line {
    margin: 0 0 12px;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #2563eb;
  }

  .hero-title {
    margin: 0 0 18px;
    font-size: clamp(2.3rem, 6vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    font-weight: 900;
  }

  .hero-summary {
    margin: 0;
    font-size: 1.12rem;
    color: var(--text-soft);
    max-width: 760px;
  }

  .hero-actions {
    margin-top: 22px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    background: var(--primary);
    color: #fff;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 700;
    transition: 0.2s ease;
    box-shadow: 0 8px 22px -12px rgba(37, 99, 235, 0.55);
  }

  .hero-btn:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
  }

  .category-card {
    position: relative;
    border: 1px solid var(--line);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, var(--category-glow), transparent 34%),
      linear-gradient(180deg, #ffffff 0%, #fdfdfd 100%);
    box-shadow: 0 18px 40px -30px rgba(15, 23, 42, 0.18);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .category-card::after {
    content: "";
    position: absolute;
    right: -8%;
    top: 18px;
    width: 44%;
    height: 116px;
    border: 1px solid color-mix(in srgb, var(--category) 14%, transparent);
    border-left: 0;
    border-radius: 999px;
    opacity: 0.8;
    pointer-events: none;
  }

  .category-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--category) 35%, #d6dbe4);
    box-shadow: 0 28px 48px -30px rgba(15, 23, 42, 0.22);
  }

  .card-inner {
    padding: 26px 24px 22px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-header {
    margin-bottom: 22px;
  }

  .category-header-main {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }

  .category-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 18px;
    background: var(--category-soft);
    border: 1px solid var(--category-soft-border);
    color: var(--category);
    flex-shrink: 0;
  }

  .category-icon,
  .tool-icon,
  .more-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .category-icon :global(svg) {
    width: 28px;
    height: 28px;
  }

  .category-copy {
    min-width: 0;
    flex: 1;
  }

  .card-title-row {
    margin-bottom: 10px;
  }

  .card-title-row h2 {
    margin: 0;
    font-size: 1.95rem;
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .card-meta-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
  }

  .card-header p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.62;
    font-size: 1.02rem;
    max-width: 30ch;
  }

  .category-link:hover {
    color: var(--category);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: var(--category-badge);
    color: var(--category-badge-text);
    font-size: 0.74rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tool-list {
    display: grid;
    gap: 12px;
    margin: 0 0 14px;
  }

  .tool-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    background: #ffffff;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .tool-row:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--category) 28%, #d6dbe4);
    box-shadow: 0 18px 30px -26px var(--category-glow);
  }

  .tool-row-static:hover {
    transform: none;
    border-color: #e5e7eb;
    box-shadow: none;
  }

  .tool-leading {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    min-width: 0;
    flex: 1;
  }

  .tool-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 14px;
    background: var(--category-soft);
    border: 1px solid var(--category-soft-border);
    color: var(--category);
  }

  .tool-icon :global(svg),
  .more-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .tool-copy {
    min-width: 0;
  }

  .tool-name {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.38;
    color: var(--text);
  }

  .tool-desc {
    display: block;
    margin-top: 4px;
    color: var(--text-soft);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .tool-trailing {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    margin-left: 10px;
  }

  .tool-status {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0 10px;
    border-radius: 999px;
    background: #f3f4f6;
    color: #6b7280;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .arrow,
  .more-arrow {
    flex-shrink: 0;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--primary);
    transition: transform 0.18s ease;
  }

  .tool-row:hover .arrow,
  .more-link:hover .more-arrow {
    transform: translateX(2px);
  }

  .arrow-muted {
    color: #94a3b8;
  }

  .more-link {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
    min-height: 46px;
    padding: 0 16px;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #ffffff;
    font-size: 1rem;
    font-weight: 800;
    color: var(--primary);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .more-link:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--category) 28%, #d6dbe4);
  }

  .more-icon {
    color: var(--category);
  }

  .more-arrow {
    margin-left: auto;
  }

  .seo-statement {
    padding: 60px 0 20px;
  }

  .statement-inner {
    border-left: 3px solid var(--text);
    padding-left: 32px;
    max-width: 850px;
  }

  .statement-inner p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-soft);
    margin: 0;
  }

  .statement-inner strong {
    color: var(--text);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .home-hero {
      padding-top: 18px;
    }

    .hero-title {
      font-size: 2.3rem;
    }

    .hero-summary {
      font-size: 1rem;
    }

    .hero-btn {
      width: 100%;
    }

    .card-inner {
      padding: 20px 18px 18px;
    }

    .category-header-main {
      gap: 14px;
    }

    .category-icon-wrap {
      width: 48px;
      height: 48px;
      border-radius: 16px;
    }

    .category-icon :global(svg) {
      width: 24px;
      height: 24px;
    }

    .card-meta-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .card-title-row h2 {
      font-size: 1.6rem;
    }

    .badge {
      margin-top: 0;
    }

    .tool-row,
    .tool-row-static {
      align-items: flex-start;
    }

    .tool-trailing {
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
      margin-left: 0;
    }

    .statement-inner {
      padding-left: 20px;
    }

    .statement-inner p {
      font-size: 1rem;
    }
  }
</style>
