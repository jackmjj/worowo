---
// worowo - All-in-One Minimalist Dashboard
const categories = [
  {
    title: "Quotes & Invoices",
    badge: "Document",
    description: "Professional docs in seconds — ready to send or print.",
    tools: [
      { name: "Quote / Estimate Generator", slug: "quote-generator" },
      { name: "Invoice Generator", slug: "invoice-generator" },
      { name: "Proforma Invoice Generator", slug: "proforma-invoice" },
      { name: "Receipt Generator", slug: "receipt-generator" },
    ],
    href: "/quotes-invoices/",
  },
  {
    title: "Packing & Shipping",
    badge: "Logistics",
    description: "Shipping paperwork without opening complex software.",
    tools: [
      { name: "Packing Slip Generator", slug: "packing-slip" },
      { name: "Packing List Generator", slug: "packing-list" },
      { name: "Delivery Note Generator", slug: "delivery-note" },
    ],
    href: "/packing-shipping/",
  },
  {
    title: "Business Calculators",
    badge: "Finance",
    description: "Quick answers to the numbers that matter.",
    tools: [
      { name: "Profit Margin Calculator", slug: "margin-calculator" },
      { name: "Markup Calculator", slug: "markup-calculator" },
      { name: "Break-even Calculator", slug: "break-even" },
      { name: "Landed Cost Calculator", slug: "landed-cost" },
    ],
    href: "/calculators/",
  },
  {
    title: "Printable Templates",
    badge: "Static",
    description: "Download and print — no editing required.",
    tools: [
      { name: "Blank Invoice Template", slug: "blank-invoice" },
      { name: "Packing List Template", slug: "manual-packing-list" },
      { name: "Checklist / Duty Roster", slug: "checklist" },
    ],
    href: "/templates/",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>worowo — Skip the Software. Get the Result.</title>
    <meta name="description" content="Instant business tools: Invoices, quotes, and packing documents in seconds." />
    <link rel="canonical" href="https://www.worowo.com/" />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">worowo</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container text-center">
          <p class="eyebrow">Instant tools for business tasks</p>
          <h1>Skip the Software. <br />Get the Result.</h1>
          <p class="hero-text">
            Generate invoices, quotes, packing documents, and business calculations
            in seconds. <strong>No account, no setup, just results.</strong>
          </p>
        </div>
      </section>

      <section id="tools" class="section">
        <div class="container">
          <div class="category-grid">
            {categories.map((category) => (
              <div class="category-card">
                <div class="card-inner">
                  <header class="card-header">
                    <span class="badge">{category.badge}</span>
                    <h2>{category.title}</h2>
                    <p>{category.description}</p>
                  </header>

                  <div class="tool-list">
                    {category.tools.map((tool) => (
                      <a href={`${category.href}${tool.slug}/`} class="tool-row">
                        <span class="tool-name">{tool.name}</span>
                        <span class="arrow">→</span>
                      </a>
                    ))}
                  </div>
                  
                  <a href={category.href} class="view-all">Explore Category →</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-summary-grid">
          <div class="summary-box">
            <h3>About</h3>
            <p>worowo is a lightweight toolkit for everyday tasks. Built for people who want clean results fast — without accounts or learning curves.</p>
          </div>
          <div class="summary-box">
            <h3>Privacy</h3>
            <p>Your data stays on your device. Most tools run entirely in your browser, and we aim to collect zero personal information.</p>
          </div>
          <div class="summary-box">
            <h3>Terms</h3>
            <p>Tools are provided as-is. Please review all generated results before use in real commercial transactions.</p>
          </div>
        </div>

        <div class="footer-bottom">
          <div class="footer-bottom-inner">
            <span class="logo-small">worowo</span>
            <div class="footer-contact">
              <span>Feedback: <a href="mailto:hello@worowo.com">hello@worowo.com</a></span>
            </div>
            <p class="copyright">© 2026 worowo. Get the result.</p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --text: #0f172a;
    --text-soft: #64748b;
    --bg-soft: #f8fafc;
    --line: #e2e8f0;
    --primary: #2563eb;
    --font-stack: system-ui, -apple-system, sans-serif;
  }

  * { box-sizing: border-box; }
  body { 
    margin: 0; 
    background: #ffffff; 
    color: var(--text); 
    font-family: var(--font-stack); 
    line-height: 1.5; 
    -webkit-font-smoothing: antialiased; 
  }

  .container { width: min(1100px, calc(100% - 40px)); margin: 0 auto; }
  .text-center { text-align: center; display: flex; flex-direction: column; align-items: center; }

  /* Header */
  .site-header { 
    height: 64px; 
    display: flex; 
    align-items: center; 
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(10px);
    z-index: 100;
  }
  .header-inner { display: flex; justify-content: center; width: 100%; }
  .logo { font-size: 1.3rem; font-weight: 900; letter-spacing: -0.05em; text-transform: lowercase; text-decoration: none; color: var(--text); }

  /* Hero */
  .hero { padding: 90px 0 50px; }
  .eyebrow { color: var(--primary); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px; }
  h1 { font-size: clamp(2.3rem, 6vw, 3.8rem); line-height: 1.05; letter-spacing: -0.04em; margin: 0 0 20px; font-weight: 900; }
  .hero-text { font-size: 1.2rem; color: var(--text-soft); max-width: 600px; margin: 0; }

  /* Grid */
  .section { padding-bottom: 80px; }
  .category-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }

  .category-card { border: 1px solid var(--line); border-radius: 12px; background: #fff; transition: 0.2s; }
  .category-card:hover { border-color: var(--text); box-shadow: 0 10px 30px -15px rgba(0,0,0,0.08); }
  .card-inner { padding: 32px; display: flex; flex-direction: column; height: 100%; }
  
  .badge { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-soft); background: var(--bg-soft); padding: 3px 8px; border-radius: 4px; display: inline-block; margin-bottom: 12px; }
  .card-header h2 { font-size: 1.55rem; font-weight: 850; margin: 0 0 8px; letter-spacing: -0.02em; }
  .card-header p { color: var(--text-soft); margin: 0 0 24px; font-size: 0.95rem; line-height: 1.4; }

  /* Tool List */
  .tool-list { border-top: 2px solid var(--text); margin-bottom: 24px; }
  .tool-row { 
    display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px dotted var(--line); 
    text-decoration: none; color: var(--text); font-weight: 600; font-size: 0.95rem;
  }
  .tool-row:hover { color: var(--primary); border-bottom-style: solid; border-bottom-color: var(--text); }
  .tool-row .arrow { color: var(--line); transition: 0.2s; }
  .tool-row:hover .arrow { transform: translateX(4px); color: var(--text); }

  .view-all { margin-top: auto; font-size: 0.85rem; font-weight: 700; color: var(--text-soft); text-decoration: none; }

  /* Footer: About/Privacy/Terms Grid */
  .site-footer { border-top: 1px solid var(--line); background: var(--bg-soft); padding: 80px 0 40px; margin-top: 40px; }
  
  .footer-summary-grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 40px; 
    padding-bottom: 60px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 40px;
  }
  
  .summary-box h3 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 16px; color: var(--text); font-weight: 800; }
  .summary-box p { font-size: 0.9rem; color: var(--text-soft); margin: 0; line-height: 1.6; }

  .footer-bottom-inner { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    flex-wrap: wrap; 
    gap: 20px;
  }
  
  .logo-small { font-weight: 900; font-size: 1.1rem; letter-spacing: -0.04em; }
  .footer-contact { font-size: 0.85rem; color: var(--text-soft); }
  .footer-contact a { color: var(--text); font-weight: 600; text-decoration: none; }
  .copyright { font-size: 0.85rem; color: var(--text-soft); margin: 0; }

  /* Responsive */
  @media (max-width: 900px) {
    .category-grid, .footer-summary-grid { grid-template-columns: 1fr; }
    .footer-summary-grid { gap: 32px; }
  }

  @media (max-width: 600px) {
    .hero { padding: 60px 0; }
    .card-inner { padding: 24px; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }
</style>