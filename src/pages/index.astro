---
const categories = [
  {
    title: "Quotes & Invoices",
    badge: "Document",
    description:
      "Generate professional business documents in seconds — ready to send or print.",
    tools: [
      {
        name: "Quote / Estimate Generator",
        desc: "Create a clean price quote to send to a client",
        slug: "quote-generator",
      },
      {
        name: "Invoice Generator",
        desc: "Generate a professional invoice, ready to send or print",
        slug: "invoice-generator",
      },
      {
        name: "Proforma Invoice Generator",
        desc: "Issue a proforma before the sale is confirmed",
        slug: "proforma-invoice",
      },
      {
        name: "Receipt Generator",
        desc: "Provide a simple proof of payment",
        slug: "receipt-generator",
      },
    ],
    href: "/quotes-invoices/",
  },
  {
    title: "Packing & Shipping",
    badge: "Logistics",
    description: "Accurate shipping paperwork without opening complex software.",
    tools: [
      {
        name: "Packing Slip Generator",
        desc: "List the items included in a shipment",
        slug: "packing-slip",
      },
      {
        name: "Packing List Generator",
        desc: "Detailed list for larger or multi-box shipments",
        slug: "packing-list",
      },
      {
        name: "Delivery Note Generator",
        desc: "Confirm what was delivered and when",
        slug: "delivery-note",
      },
    ],
    href: "/packing-shipping/",
  },
  {
    title: "Business Calculators",
    badge: "Finance",
    description: "Quick answers to the numbers that matter.",
    tools: [
      {
        name: "Profit Margin Calculator",
        desc: "Find out exactly how much you're making per sale",
        slug: "margin-calculator",
      },
      {
        name: "Markup Calculator",
        desc: "Set the right selling price from your cost",
        slug: "markup-calculator",
      },
      {
        name: "Break-even Calculator",
        desc: "Know the minimum price to cover your costs",
        slug: "break-even",
      },
      {
        name: "Landed Cost Calculator",
        desc: "Factor in shipping, tax, and fees into true cost",
        slug: "landed-cost",
      },
    ],
    href: "/calculators/",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>worowo — Skip the Software. Get the Result.</title>
    <meta
      name="description"
      content="Generate invoices, quotes, packing documents, and business calculations in seconds. Ready to print or send. No account needed."
    />
    <link rel="canonical" href="https://www.worowo.com/" />
    <meta name="theme-color" content="#ffffff" />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">worowo</a>
        <nav class="nav">
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
          <a href="#privacy">Privacy</a>
          <a href="#terms">Terms</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-inner">
          <p class="eyebrow">Instant tools for business tasks</p>
          <h1>Skip the Software. <br />Get the Result.</h1>
          <p class="hero-text">
            Generate invoices, quotes, packing documents, and business calculations
            in seconds.
            <strong>
              Ready to print or send. No account needed. No setup. Just the tool you came for.
            </strong>
          </p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="#tools">Start Generating</a>
            <a class="btn btn-secondary" href="/quotes-invoices/invoice-generator/">
              Create an Invoice
            </a>
          </div>
        </div>
      </section>

      <section id="tools" class="section">
        <div class="container">
          <div class="category-grid">
            {categories.map((category) => (
              <article class="category-block">
                <div class="category-header">
                  <span class="category-badge">{category.badge}</span>
                  <h2>{category.title}</h2>
                  <p>{category.description}</p>
                </div>

                <div class="tool-list-container">
                  {category.tools.map((tool) => (
                    <a href={`${category.href}${tool.slug}/`} class="tool-item">
                      <div class="tool-info">
                        <span class="tool-name">{tool.name}</span>
                        <span class="tool-desc">{tool.desc}</span>
                      </div>
                      <span class="arrow">→</span>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bottom-section section-soft" id="about">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>About</h2>
          </div>
          <p class="bottom-text">
            worowo is a lightweight toolkit for everyday business tasks. It is
            built for people who want clean results fast — without opening
            complicated software, creating an account, or learning a full editor.
          </p>
          <p class="bottom-text">
            The goal is simple: turn small but necessary business tasks into tools
            that are practical, fast, and ready to use.
          </p>
        </div>
      </section>

      <section class="bottom-section" id="contact">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>Contact</h2>
          </div>
          <p class="bottom-text">
            For feedback, support, or partnership inquiries, contact:
          </p>
          <p class="bottom-text">
            <a href="mailto:hello@worowo.com" class="inline-link">hello@worowo.com</a>
          </p>
        </div>
      </section>

      <section class="bottom-section section-soft" id="privacy">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>Privacy</h2>
          </div>
          <p class="bottom-text">
            worowo aims to collect as little information as possible. When a tool
            works entirely in your browser, your data stays on your device.
          </p>
          <p class="bottom-text">
            If a future tool requires server-side processing, only the minimum
            necessary information will be used to provide that function.
          </p>
        </div>
      </section>

      <section class="bottom-section" id="terms">
        <div class="container narrow">
          <div class="bottom-heading">
            <h2>Terms</h2>
          </div>
          <p class="bottom-text">
            worowo provides practical tools for general business use. Users are
            responsible for reviewing generated results before sending, printing,
            or using them in real transactions.
          </p>
          <p class="bottom-text">
            The tools are provided as-is, without guarantees of suitability for
            every legal, tax, logistics, or commercial requirement in every
            country or situation.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="logo">worowo</span>
        <p class="copyright">
          © 2026 worowo. Skip the Software. Get the Result.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --text: #0f172a;
    --text-soft: #64748b;
    --bg: #ffffff;
    --bg-soft: #f8fafc;
    --line: #e2e8f0;
    --font-stack: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-stack);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    width: min(1160px, calc(100% - 40px));
    margin: 0 auto;
  }

  .narrow {
    max-width: 800px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Header */
  .logo {
    font-size: 1.3rem;
    font-weight: 850;
    letter-spacing: -0.05em;
    text-transform: lowercase;
    text-decoration: none;
    color: var(--text);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-soft);
    text-decoration: none;
  }

  .nav a:hover,
  .inline-link:hover {
    color: var(--primary);
  }

  /* Hero */
  .hero {
    padding: 90px 0 70px;
  }

  .eyebrow {
    color: var(--primary);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    font-weight: 900;
  }

  .hero-text {
    font-size: 1.25rem;
    color: var(--text-soft);
    max-width: 760px;
    margin-bottom: 36px;
  }

  .hero-text strong {
    color: var(--text);
  }

  /* Buttons */
  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: 0.2s;
  }

  .btn-primary {
    background: var(--text);
    color: #fff;
  }

  .btn-primary:hover {
    background: #000;
    transform: translateY(-1px);
  }

  .btn-secondary {
    border: 1px solid var(--line);
    color: var(--text);
  }

  .btn-secondary:hover {
    background: var(--bg-soft);
  }

  /* Main tools section */
  .section {
    padding: 60px 0 100px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
    gap: 48px;
  }

  .category-block {
    scroll-margin-top: 90px;
  }

  .category-header {
    margin-bottom: 24px;
  }

  .category-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-soft);
    background: var(--bg-soft);
    padding: 4px 8px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .category-header h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .category-header p {
    color: var(--text-soft);
    margin: 0;
    font-size: 1rem;
  }

  /* Tool items */
  .tool-list-container {
    display: flex;
    flex-direction: column;
    border-top: 2px solid var(--text);
  }

  .tool-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: 0.2s;
  }

  .tool-item:hover {
    padding-left: 8px;
    border-bottom-color: var(--text);
  }

  .tool-item:hover .tool-name {
    color: var(--primary);
  }

  .tool-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tool-name {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .tool-desc {
    font-size: 0.9rem;
    color: var(--text-soft);
  }

  .arrow {
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--line);
    transition: 0.2s;
  }

  .tool-item:hover .arrow {
    color: var(--text);
    transform: translateX(4px);
  }

  /* Bottom sections */
  .bottom-section {
    padding: 56px 0;
    scroll-margin-top: 84px;
  }

  .section-soft {
    background: var(--bg-soft);
  }

  .bottom-heading {
    margin-bottom: 16px;
  }

  .bottom-heading h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .bottom-text {
    font-size: 1rem;
    color: var(--text-soft);
    margin: 0 0 12px;
  }

  .inline-link {
    color: var(--text);
    font-weight: 600;
  }

  /* Footer */
  .site-footer {
    padding: 36px 0 40px;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--text-soft);
    margin: 0;
  }

  @media (max-width: 900px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px 0;
    }

    .hero-actions .btn {
      width: 100%;
    }

    .header-inner {
      height: auto;
      padding: 14px 0;
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .nav {
      gap: 12px 16px;
    }
  }

  @media (max-width: 600px) {
    .container {
      width: min(1160px, calc(100% - 24px));
    }

    .hero-text {
      font-size: 1.06rem;
      margin-bottom: 28px;
    }

    .section {
      padding: 42px 0 72px;
    }

    .bottom-section {
      padding: 40px 0;
    }

    .category-header h2,
    .bottom-heading h2 {
      font-size: 1.45rem;
    }

    .tool-item {
      padding: 16px 0;
    }

    .tool-name {
      font-size: 1rem;
    }

    .tool-desc {
      font-size: 0.86rem;
    }
  }
</style>