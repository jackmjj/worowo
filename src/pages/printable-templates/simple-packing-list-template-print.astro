---
import PackingListDocument from "../../components/printable/documents/PackingListDocument.astro";
import PrintableDocumentShell from "../../components/printable/PrintableDocumentShell.astro";
import PrintableTemplatePrintLayout from "../../layouts/PrintableTemplatePrintLayout.astro";
import { getPrintableTemplateConfig } from "../../lib/printable/config";

const config = getPrintableTemplateConfig("simple-packing-list-template");
---

<PrintableTemplatePrintLayout
  pageTitle={config.printTitle}
  description={config.description}
  defaultPaper={config.defaultPaper}
  orientation={config.defaultOrientation}
  supportedPapers={config.supportedPapers}
  backHref="/printable-templates/simple-packing-list-template/"
  canonical={config.canonical}
  recommendedPaperNote={config.recommendedPaperNote}
>
  <PrintableDocumentShell dynamicPaper={true} orientation={config.defaultOrientation}>
    <PackingListDocument />
  </PrintableDocumentShell>
</PrintableTemplatePrintLayout>
