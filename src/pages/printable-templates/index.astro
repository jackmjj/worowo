---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { printableTemplateEntries } from "../../data/printableTemplates";

const sections = [
  {
    title: "Quote & Billing",
    tools: printableTemplateEntries.filter((tool) => tool.category === "Quote & Billing"),
  },
  {
    title: "Packing & Shipping",
    tools: printableTemplateEntries.filter((tool) => tool.category === "Packing & Shipping"),
  },
  {
    title: "Employee Scheduling & HR",
    tools: printableTemplateEntries.filter((tool) => tool.category === "Employee Scheduling & HR"),
  },
  {
    title: "Retail Cash & Store Operations",
    tools: printableTemplateEntries.filter((tool) => tool.category === "Retail Cash & Store Operations"),
  },
  {
    title: "Field Service & Job Forms",
    tools: printableTemplateEntries.filter((tool) => tool.category === "Field Service & Job Forms"),
  },
];
---

<BaseLayout
  title="Printable Templates | worowo"
  description="Free printable business templates for invoicing, packing, shipping, employee scheduling, cash reconciliation, and field service paperwork."
  canonical="https://www.worowo.com/printable-templates/"
>
  <main class="templates-page">
    <section class="templates-hero">
      <div class="container">
        <nav class="templates-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>&gt;</span>
          <span>Printable Templates</span>
        </nav>

        <div class="hero-copy">
          <p class="eyebrow">Printable Templates</p>
          <h1 class="page-title">Printable Templates</h1>
          <p class="page-summary">
            Ready-to-print business templates for billing, shipping, employee scheduling, store operations, and field service documentation.
          </p>
        </div>
      </div>
    </section>

    <section class="templates-main">
      <div class="container">
        {sections.map((section) => (
          section.tools.length > 0 && (
            <section class="template-section">
              <div class="section-heading">
                <p class="section-kicker">Category</p>
                <h2>{section.title}</h2>
              </div>

              <div class="template-grid">
                {section.tools.map((tool) => (
                  <a class="template-card" href={`/printable-templates/${tool.slug}/`}>
                    <span class="template-tag">{tool.category}</span>
                    <h3>{tool.cardTitle}</h3>
                    <p>{tool.metaDescription}</p>
                    <span class="template-arrow">→</span>
                  </a>
                ))}
              </div>
            </section>
          )
        ))}
      </div>
    </section>
  </main>

  <style>
    .templates-page {
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .templates-hero {
      padding: 22px 0 24px;
    }

    .templates-breadcrumb {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 0 0 16px;
      color: var(--text-soft);
      font-size: 0.9rem;
    }

    .templates-main {
      padding: 12px 0 42px;
    }

    .template-section + .template-section {
      margin-top: 34px;
    }

    .section-heading {
      margin-bottom: 16px;
    }

    .section-kicker {
      margin: 0 0 6px;
      color: var(--primary);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .section-heading h2 {
      margin: 0;
      font-size: 1.55rem;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .template-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
    }

    .template-card {
      position: relative;
      display: block;
      padding: 24px;
      background: #ffffff;
      border: 1px solid var(--line);
      border-radius: 16px;
      box-shadow: 0 16px 40px -28px rgba(15, 23, 42, 0.25);
      transition: transform 0.18s ease, border-color 0.18s ease;
    }

    .template-card:hover {
      transform: translateY(-2px);
      border-color: var(--text);
    }

    .template-tag {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      margin-bottom: 12px;
      border-radius: 999px;
      background: #dbeafe;
      color: #2563eb;
      font-size: 0.82rem;
      font-weight: 800;
    }

    .template-card h3 {
      margin: 0 0 8px;
      font-size: 1.08rem;
      line-height: 1.35;
    }

    .template-card p {
      margin: 0;
      color: var(--text-soft);
      line-height: 1.7;
      font-size: 0.94rem;
      max-width: 34ch;
    }

    .template-arrow {
      position: absolute;
      top: 22px;
      right: 22px;
      color: var(--primary);
      font-weight: 700;
    }

    @media (max-width: 980px) {
      .template-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
