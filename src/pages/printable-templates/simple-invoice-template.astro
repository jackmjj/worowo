---
import InvoiceDocument from "../../components/printable/documents/InvoiceDocument.astro";
import PrintableDocumentShell from "../../components/printable/PrintableDocumentShell.astro";
import PrintableTemplatePageLayout from "../../layouts/PrintableTemplatePageLayout.astro";
import { getPrintableTemplateConfig } from "../../lib/printable/config";

const config = getPrintableTemplateConfig("simple-invoice-template");
const previewPaper = config.previewPaper ?? config.defaultPaper;
const previewOrientation = config.previewOrientation ?? config.defaultOrientation;
---

<PrintableTemplatePageLayout
  pageTitle={config.pageTitle}
  description={config.description}
  eyebrow={config.pageEyebrow}
  previewTitle={config.previewTitle!}
  previewDescription={config.previewDescription!}
  printHref="/printable-templates/simple-invoice-template-print/"
  canonical={config.canonical}
>
  <Fragment slot="preview">
    <PrintableDocumentShell paper={previewPaper} orientation={previewOrientation}>
      <InvoiceDocument />
    </PrintableDocumentShell>
  </Fragment>

  <div slot="note" class="helper-note">
    This invoice template now uses the shared printable base system and supports
    both A4 and US Letter from the print page.
  </div>
</PrintableTemplatePageLayout>
