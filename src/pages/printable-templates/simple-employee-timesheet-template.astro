---
import PrintableTemplatePageLayout from "../../layouts/PrintableTemplatePageLayout.astro";
import { getPrintableTemplateConfig } from "../../lib/printable/config";

const config = getPrintableTemplateConfig("simple-employee-timesheet-template");

const days = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];
---

<PrintableTemplatePageLayout
  pageTitle={config.pageTitle}
  description={config.description}
  eyebrow={config.pageEyebrow}
  previewTitle={config.previewTitle!}
  previewDescription={config.previewDescription!}
  printHref={`/printable-templates/${config.slug}-print/`}
  canonical={config.canonical}
>
  <Fragment slot="preview">
    <div class="paper letter portrait" aria-label="Employee timesheet preview">
      <div class="doc-header">
        <div class="doc-title">EMPLOYEE TIMESHEET</div>
        <div class="doc-meta">
          <div class="field-row">
            <span class="field-label">Week Beginning:</span>
            <span class="field-line"></span>
          </div>
          <div class="field-row">
            <span class="field-label">Week Ending:</span>
            <span class="field-line"></span>
          </div>
        </div>
      </div>

      <section class="doc-section">
        <h3 class="section-title">Employee Information</h3>
        <div class="box">
          <div class="two-col">
            <div>
              <div class="field-row">
                <span class="field-label">Employee Name:</span>
                <span class="field-line"></span>
              </div>
              <div class="field-row">
                <span class="field-label">Employee ID:</span>
                <span class="field-line"></span>
              </div>
              <div class="field-row">
                <span class="field-label">Department:</span>
                <span class="field-line"></span>
              </div>
            </div>

            <div>
              <div class="field-row">
                <span class="field-label">Position:</span>
                <span class="field-line"></span>
              </div>
              <div class="field-row">
                <span class="field-label">Supervisor:</span>
                <span class="field-line"></span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="doc-section">
        <h3 class="section-title">Weekly Time Entry</h3>
        <table class="doc-table timesheet-table">
          <thead>
            <tr>
              <th style="width: 12%;">Day</th>
              <th style="width: 10%;">Date</th>
              <th style="width: 11%;">Time In</th>
              <th style="width: 11%;">Meal Out</th>
              <th style="width: 11%;">Meal In</th>
              <th style="width: 11%;">Time Out</th>
              <th style="width: 12%;">Regular Hours</th>
              <th style="width: 10%;">OT Hours</th>
              <th style="width: 12%;">Notes</th>
            </tr>
          </thead>
          <tbody>
            {days.map((day) => (
              <tr>
                <td>{day}</td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section class="doc-section">
        <div class="two-col">
          <div class="box">
            <h3 class="section-title">Notes</h3>
            <div class="notes-lines">
              <div class="notes-line"></div>
              <div class="notes-line"></div>
            </div>
          </div>

          <div class="box">
            <h3 class="section-title">Hours Summary</h3>
            <div class="field-row">
              <span class="field-label">Total Regular Hours:</span>
              <span class="field-line"></span>
            </div>
            <div class="field-row">
              <span class="field-label">Total Overtime Hours:</span>
              <span class="field-line"></span>
            </div>
            <div class="field-row">
              <span class="field-label">Total Hours:</span>
              <span class="field-line"></span>
            </div>
          </div>
        </div>
      </section>

      <section class="doc-section">
        <h3 class="section-title">Certification</h3>
        <div class="signature-grid timesheet-signatures">
          <div class="box">
            <div class="field-row">
              <span class="field-label">Employee Signature:</span>
              <span class="field-line"></span>
            </div>
            <div class="field-row">
              <span class="field-label">Date:</span>
              <span class="field-line"></span>
            </div>
          </div>

          <div class="box">
            <div class="field-row">
              <span class="field-label">Supervisor Signature:</span>
              <span class="field-line"></span>
            </div>
            <div class="field-row">
              <span class="field-label">Date:</span>
              <span class="field-line"></span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </Fragment>

  <div slot="note" class="helper-note">
    This timesheet template is designed for weekly employee hour tracking, including
    breaks, overtime, and signature approval. It is available in both US Letter and
    A4 print formats.
  </div>
</PrintableTemplatePageLayout>

<style>
  .timesheet-table td {
    height: 34px;
    vertical-align: top;
  }

  .timesheet-table th,
  .timesheet-table td {
    font-size: 9.25pt;
    padding: 7px 6px;
  }

  .timesheet-signatures {
    grid-template-columns: 1fr 1fr;
  }
</style>
