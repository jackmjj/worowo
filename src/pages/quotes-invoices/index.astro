---
import ToolListSection from "../../components/tools/ToolListSection.astro";
import ToolCategoryPageLayout from "../../layouts/ToolCategoryPageLayout.astro";

const billingTools = [
  {
    title: "Invoice Generator",
    description: "Create customer invoices with items, totals, and payment-ready billing details.",
    icon: "invoice",
    status: "Coming soon",
  },
  {
    title: "Quote / Estimate Generator",
    description: "Prepare quotes and estimates for products or services with customer info and totals.",
    icon: "quote",
    status: "Coming soon",
  },
  {
    title: "Proforma Invoice Generator",
    description: "Create proforma invoices for international trade and pre-sale confirmation.",
    icon: "invoice",
    status: "Coming soon",
  },
  {
    title: "Receipt Generator",
    description: "Generate simple receipts for payments received, cash sales, and record keeping.",
    icon: "receipt",
    status: "Coming soon",
  },
];
---

<ToolCategoryPageLayout
  title="Quotes & Invoices"
  description="Create quotes, invoices, proforma invoices, and receipts with clean layouts built for small businesses, service providers, and trade use."
  eyebrow="Category"
  canonical="https://www.worowo.com/quotes-invoices/"
  theme="blue"
>
  <ToolListSection
    title="Quote & Billing Tools"
    description="Use these tools to prepare customer-facing billing documents quickly and generate clean quote and invoice workflows."
    tools={billingTools}
    theme="blue"
  />
</ToolCategoryPageLayout>
