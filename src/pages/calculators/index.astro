---
import BaseLayout from "../../layouts/BaseLayout.astro";

const targetHref = "/business-calculators/";
const targetUrl = "https://www.worowo.com/business-calculators/";
---

<BaseLayout
  title="Calculators | Worowo"
  description="This page has moved to Business Calculators."
  canonical={targetUrl}
  noindex={true}
>
  <main class="alias-page">
    <div class="alias-card">
      <span class="alias-eyebrow">Category Moved</span>
      <h1>Business Calculators</h1>
      <p>
        This category now lives at <a href={targetHref}>{targetHref}</a>.
      </p>
    </div>
  </main>

  <script define:vars={{ targetHref }} is:inline>
    window.location.replace(targetHref);
  </script>
</BaseLayout>

<style>
  .alias-page {
    min-height: 55vh;
    display: grid;
    place-items: center;
    padding: 48px 16px 72px;
    background: #f8fafc;
  }

  .alias-card {
    width: min(720px, 100%);
    padding: 28px;
    border: 1px solid #dbe3ee;
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
  }

  .alias-eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .alias-card h1 {
    margin: 0 0 10px;
    font-size: clamp(32px, 4vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #0f172a;
  }

  .alias-card p {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: #475569;
  }

  .alias-card a {
    color: #7c3aed;
    font-weight: 700;
  }
</style>
