---
import ToolListSection from "../../components/tools/ToolListSection.astro";
import { getCategoryPageData } from "../../data/categoryPageData";
import ToolCategoryPageLayout from "../../layouts/ToolCategoryPageLayout.astro";

const page = getCategoryPageData("packing_shipping");
---

<ToolCategoryPageLayout
  title={page.title}
  description={page.description}
  eyebrow={page.eyebrow}
  canonical="https://www.worowo.com/packing-shipping/"
  theme={page.theme}
>
  {page.sections.map((section) => (
    <ToolListSection
      title={section.title}
      description={section.description}
      tools={section.tools}
      theme={page.theme}
    />
  ))}
</ToolCategoryPageLayout>
