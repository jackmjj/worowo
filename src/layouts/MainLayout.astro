---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Worowo | Fast Online Tools",
  description = "Worowo 是一个正在建设中的在线工具站，先从一个清晰、轻量的首页开始。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
