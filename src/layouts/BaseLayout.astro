---
import { siteNavigation } from "../data/siteNavigation";

interface NavChild {
  label: string;
  href: string;
  description?: string;
  status?: "live" | "coming_soon";
}

interface NavGroup {
  label: string;
  href?: string;
  theme?: "blue" | "green" | "purple" | "orange";
  children?: NavChild[];
}

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  navGroups?: NavGroup[];
}

const {
  title,
  description = "Business tools, printable templates, and practical utilities for everyday work.",
  canonical,
  noindex = false,
  navGroups,
} = Astro.props;

const defaultNavGroups = siteNavigation
  .filter((section) => section.showInHeader !== false)
  .map((section) => ({
    label: section.title,
    href: section.href,
    theme: section.theme,
    children: section.children
      .filter((child) => child.showInMenu !== false && child.featuredInMenu !== false)
      .map((child) => ({
        label: child.title,
        href: child.href,
        description: child.description,
        status: child.status,
      })),
  }));

const headerNavGroups = navGroups ?? defaultNavGroups;
const canonicalUrl = canonical || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RTRDKV4HF5"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-RTRDKV4HF5");
    </script>

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-soft: #f8fafc;
        --card: #ffffff;
        --text: #0f172a;
        --text-soft: #475569;
        --line: #e2e8f0;
        --line-strong: #cbd5e1;
        --primary: #2563eb;
        --primary-soft: #dbeafe;
        --container: 1120px;
        --radius: 18px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        width: min(var(--container), calc(100% - 32px));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 40;
        background: rgba(255, 255, 255, 0.94);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }

      .header-row {
        min-height: 78px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .site-logo {
        font-size: 1.9rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        line-height: 1;
      }

      .site-logo:hover {
        color: var(--primary);
      }

      .desktop-nav {
        display: flex;
        align-items: center;
        gap: 18px;
      }

      .desktop-nav > a,
      .desktop-nav summary,
      .desktop-trigger {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        cursor: pointer;
        list-style: none;
      }

      .desktop-group {
        position: relative;
        padding-bottom: 10px;
        margin-bottom: -10px;
      }

      .desktop-trigger {
        appearance: none;
        border: 0;
        background: transparent;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 6px;
        font: inherit;
        color: inherit;
        cursor: pointer;
        min-height: 44px;
      }

      .desktop-group:hover .desktop-trigger,
      .desktop-group:focus-within .desktop-trigger,
      .desktop-group[data-open="true"] .desktop-trigger {
        color: var(--primary);
      }

      .desktop-group[data-theme="green"]:hover .desktop-trigger,
      .desktop-group[data-theme="green"]:focus-within .desktop-trigger,
      .desktop-group[data-theme="green"][data-open="true"] .desktop-trigger {
        color: #16a34a;
      }

      .desktop-group[data-theme="purple"]:hover .desktop-trigger,
      .desktop-group[data-theme="purple"]:focus-within .desktop-trigger,
      .desktop-group[data-theme="purple"][data-open="true"] .desktop-trigger {
        color: #7c3aed;
      }

      .desktop-group[data-theme="orange"]:hover .desktop-trigger,
      .desktop-group[data-theme="orange"]:focus-within .desktop-trigger,
      .desktop-group[data-theme="orange"][data-open="true"] .desktop-trigger {
        color: #ea580c;
      }

      .desktop-flyout {
        position: absolute;
        top: calc(100% - 10px);
        right: 0;
        width: 320px;
        padding: 10px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: #fff;
        box-shadow: 0 24px 40px -30px rgba(15, 23, 42, 0.28);
        display: none;
        gap: 6px;
      }

      .desktop-group:hover > .desktop-flyout,
      .desktop-group:focus-within > .desktop-flyout,
      .desktop-group[data-open="true"] > .desktop-flyout {
        display: grid;
      }

      .desktop-flyout-list {
        display: grid;
        gap: 4px;
      }

      .desktop-flyout-row,
      .desktop-flyout .nav-disabled {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-height: 46px;
        padding: 0 12px;
        border: 0;
        border-radius: 10px;
        background: #fff;
        color: var(--text);
        transition: 0.18s ease;
      }

      .desktop-flyout-row:hover {
        background: var(--bg-soft);
      }

      .desktop-flyout .nav-disabled {
        color: #64748b;
        cursor: default;
      }

      .desktop-flyout-copy {
        min-width: 0;
      }

      .desktop-flyout-item-title {
        color: var(--text);
        font-size: 0.95rem;
        font-weight: 800;
        line-height: 1.35;
      }

      .nav-arrow {
        color: var(--primary);
        font-weight: 800;
        flex-shrink: 0;
      }

      .desktop-group[data-theme="green"] .nav-arrow,
      .desktop-group[data-theme="green"] .desktop-flyout-more {
        color: #16a34a;
      }

      .desktop-group[data-theme="purple"] .nav-arrow,
      .desktop-group[data-theme="purple"] .desktop-flyout-more {
        color: #7c3aed;
      }

      .desktop-group[data-theme="orange"] .nav-arrow,
      .desktop-group[data-theme="orange"] .desktop-flyout-more {
        color: #ea580c;
      }

      .nav-status {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        padding: 0 10px;
        border-radius: 999px;
        background: #f3f4f6;
        color: #6b7280;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .desktop-flyout-more {
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-height: 44px;
        margin-top: 4px;
        padding: 0 12px;
        border-top: 1px solid var(--line);
        color: var(--primary);
        font-size: 0.9rem;
        font-weight: 800;
      }

      .mobile-group-links .nav-disabled {
        display: grid;
        gap: 3px;
        padding: 8px 0 8px 12px;
        color: #94a3b8;
        font-size: 0.92rem;
        line-height: 1.45;
        cursor: default;
      }

      .mobile-group-links .nav-disabled small {
        color: #94a3b8;
        font-size: 0.8rem;
        line-height: 1.4;
      }

      .mobile-group-links .nav-disabled .nav-status {
        justify-self: flex-start;
        margin-top: 3px;
      }

      .mobile-menu-toggle {
        display: none;
        width: 42px;
        height: 42px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: #fff;
        align-items: center;
        justify-content: center;
        padding: 0;
        cursor: pointer;
      }

      .mobile-menu-toggle span {
        display: block;
        width: 18px;
        height: 2px;
        background: var(--text);
        border-radius: 999px;
        position: relative;
      }

      .mobile-menu-toggle span::before,
      .mobile-menu-toggle span::after {
        content: "";
        position: absolute;
        left: 0;
        width: 18px;
        height: 2px;
        background: var(--text);
        border-radius: 999px;
      }

      .mobile-menu-toggle span::before {
        top: -6px;
      }

      .mobile-menu-toggle span::after {
        top: 6px;
      }

      .mobile-nav-panel {
        display: none;
        border-top: 1px solid var(--line);
        background: #fff;
      }

      .mobile-nav-panel[hidden] {
        display: none !important;
      }

      .mobile-nav-inner {
        padding: 12px 0 16px;
      }

      .mobile-group {
        border-bottom: 1px solid var(--line);
      }

      .mobile-group:last-child {
        border-bottom: none;
      }

      .mobile-group summary {
        list-style: none;
        cursor: pointer;
        padding: 14px 0;
        font-weight: 700;
        font-size: 0.98rem;
        line-height: 1.4;
      }

      .mobile-group summary::marker,
      .mobile-group summary::-webkit-details-marker {
        display: none;
      }

      .mobile-group-links {
        display: none;
        gap: 4px;
        padding: 0 0 14px 0;
      }

      .mobile-group[open] .mobile-group-links {
        display: grid;
      }

      .mobile-group-links a {
        padding: 8px 0 8px 12px;
        color: var(--text-soft);
        font-size: 0.92rem;
        line-height: 1.45;
      }

      .mobile-group-links a:hover {
        color: var(--primary);
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--primary);
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .page-title {
        margin: 0 0 12px;
        font-size: clamp(2.15rem, 3vw, 2.9rem);
        line-height: 1.06;
        letter-spacing: -0.035em;
      }

      .page-summary {
        margin: 0;
        max-width: 760px;
        color: var(--text-soft);
        font-size: 1.02rem;
        line-height: 1.8;
      }

      .section-title {
        margin: 0 0 10px;
        font-size: 1.5rem;
        line-height: 1.2;
        letter-spacing: -0.02em;
      }

      .site-footer {
        margin-top: 24px;
        border-top: 1px solid var(--line);
        padding: 40px 0 28px;
        color: var(--text-soft);
        font-size: 0.95rem;
        background: var(--bg-soft);
      }

      .footer-inner {
        display: grid;
        gap: 30px;
      }

      .footer-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 18px;
      }

      .footer-brand {
        display: inline-flex;
        color: var(--text);
        font-size: 1.28rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        line-height: 1;
      }

      .footer-brand:hover {
        color: var(--primary);
      }

      .footer-tagline {
        margin: 0;
        color: var(--text-soft);
        font-size: 0.94rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 28px;
      }

      .footer-col h2,
      .footer-col h3 {
        margin: 0 0 10px;
        color: var(--text);
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .footer-col p {
        margin: 0;
        color: var(--text-soft);
        font-size: 0.92rem;
        line-height: 1.65;
      }

      .footer-col a {
        color: var(--text);
        font-weight: 700;
      }

      .footer-col a:hover {
        color: var(--primary);
      }

      .footer-bottom {
        padding-top: 8px;
        border-top: 1px solid var(--line);
      }

      .footer-bottom p {
        margin: 0;
        color: var(--text-soft);
        font-size: 0.86rem;
      }

      @media (max-width: 900px) {
        .container {
          width: min(var(--container), calc(100% - 24px));
        }

        .header-row {
          min-height: 70px;
        }

        .desktop-nav {
          display: none;
        }

        .mobile-menu-toggle {
          display: inline-flex;
          width: 44px;
          height: 44px;
        }

        .mobile-menu-toggle[aria-expanded="true"] {
          border-color: var(--line-strong);
          background: var(--bg-soft);
        }

        .site-header[data-open="true"] .mobile-nav-panel:not([hidden]) {
          display: block;
        }

        .page-summary {
          font-size: 0.98rem;
          line-height: 1.75;
        }

        .site-logo {
          font-size: 1.6rem;
        }

        .footer-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .footer-top {
          flex-direction: column;
          align-items: flex-start;
          gap: 8px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header" data-open="false" id="siteHeader">
      <div class="container">
        <div class="header-row">
          <a href="/" class="site-logo">worowo</a>

          <nav class="desktop-nav" aria-label="Primary">
            {headerNavGroups.map((group) => (
              group.children && group.children.length > 0 ? (
                <div class="desktop-group" data-theme={group.theme ?? "blue"}>
                  <a class="desktop-trigger" href={group.href || "/"}>
                    {group.label}
                  </a>
                  <div class="desktop-flyout">
                    <div class="desktop-flyout-list">
                      {group.children.map((child) => (
                        child.status === "coming_soon" ? (
                          <span class="nav-disabled">
                            <span class="desktop-flyout-copy">
                              <span class="desktop-flyout-item-title">{child.label}</span>
                            </span>
                            <span class="nav-status">Coming soon</span>
                          </span>
                        ) : (
                          <a href={child.href} class="desktop-flyout-row">
                            <span class="desktop-flyout-copy">
                              <span class="desktop-flyout-item-title">{child.label}</span>
                            </span>
                            <span class="nav-arrow">→</span>
                          </a>
                        )
                      ))}
                    </div>

                    <a href={group.href || "/"} class="desktop-flyout-more">
                      View all {group.label}
                      <span>→</span>
                    </a>
                  </div>
                </div>
              ) : (
                <a href={group.href || "/"}>{group.label}</a>
              )
            ))}
          </nav>

          <button
            class="mobile-menu-toggle"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobileNavPanel"
            id="mobileMenuToggle"
          >
            <span></span>
          </button>
        </div>
      </div>

      <div class="mobile-nav-panel" id="mobileNavPanel" hidden>
        <div class="container mobile-nav-inner">
          {headerNavGroups.map((group) => (
            <details class="mobile-group">
              <summary>{group.label}</summary>
              <div class="mobile-group-links">
                {group.href && <a href={group.href}>{group.label}</a>}
                {group.children?.map((child) => (
                  child.status === "coming_soon" ? (
                    <span class="nav-disabled">
                      <span>{child.label}</span>
                      {child.description && <small>{child.description}</small>}
                      <span class="nav-status">Coming soon</span>
                    </span>
                  ) : (
                    <a href={child.href}>{child.label}</a>
                  )
                ))}
              </div>
            </details>
          ))}
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-top">
          <a href="/" class="footer-brand">worowo</a>
          <p class="footer-tagline">Skip the Software. Get the Result.</p>
        </div>

        <div class="footer-grid">
          <section class="footer-col" aria-labelledby="footer-about-title">
            <h2 id="footer-about-title">About</h2>
            <p>
              Lightweight tools for everyday business tasks, built for fast,
              clean results without complex software.
            </p>
          </section>

          <section class="footer-col" aria-labelledby="footer-contact-title">
            <h2 id="footer-contact-title">Contact</h2>
            <p>
              Feedback or support:
              <a href="mailto:hello@worowo.com">hello@worowo.com</a>
            </p>
          </section>

          <section class="footer-col" aria-labelledby="footer-privacy-title">
            <h2 id="footer-privacy-title">Privacy</h2>
            <p>
              Most tools are designed to run directly in your browser, with
              minimal data collection.
            </p>
          </section>

          <section class="footer-col" aria-labelledby="footer-terms-title">
            <h2 id="footer-terms-title">Terms</h2>
            <p>
              Please review generated results before using them in real business
              transactions.
            </p>
          </section>
        </div>

        <div class="footer-bottom">
          <p>© 2026 worowo</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const header = document.getElementById("siteHeader");
        const toggle = document.getElementById("mobileMenuToggle");
        const panel = document.getElementById("mobileNavPanel");
        if (!header || !toggle || !panel) return;

        const desktopMedia = window.matchMedia("(min-width: 901px)");
        const desktopGroups = Array.from(header.querySelectorAll(".desktop-group"));

        const closeDesktopGroups = (except = null) => {
          desktopGroups.forEach((group) => {
            if (group !== except) {
              group.setAttribute("data-open", "false");
              const trigger = group.querySelector(".desktop-trigger");
              if (trigger) {
                trigger.setAttribute("aria-expanded", "false");
              }
            }
          });
        };

        toggle.addEventListener("click", () => {
          const open = header.getAttribute("data-open") === "true";
          header.setAttribute("data-open", open ? "false" : "true");
          toggle.setAttribute("aria-expanded", open ? "false" : "true");
          panel.hidden = open;
        });

        desktopGroups.forEach((group) => {
          const trigger = group.querySelector(".desktop-trigger");
          if (!trigger) return;

          group.setAttribute("data-open", "false");

          group.addEventListener("mouseenter", () => {
            if (!desktopMedia.matches) return;
            closeDesktopGroups(group);
            group.setAttribute("data-open", "true");
            trigger.setAttribute("aria-expanded", "true");
          });

          group.addEventListener("mouseleave", () => {
            if (!desktopMedia.matches) return;
            group.setAttribute("data-open", "false");
            trigger.setAttribute("aria-expanded", "false");
          });

          group.addEventListener("focusin", () => {
            if (!desktopMedia.matches) return;
            closeDesktopGroups(group);
            group.setAttribute("data-open", "true");
            trigger.setAttribute("aria-expanded", "true");
          });

          group.addEventListener("focusout", (event) => {
            if (!desktopMedia.matches) return;
            const nextTarget = event.relatedTarget;
            if (nextTarget instanceof Node && group.contains(nextTarget)) return;
            group.setAttribute("data-open", "false");
            trigger.setAttribute("aria-expanded", "false");
          });

        });
      })();
    </script>
  </body>
</html>
