---
import BaseLayout from "./BaseLayout.astro";

interface FaqItem {
  question: string;
  answer: string;
}

interface RelatedTool {
  name: string;
  href: string;
  desc: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  eyebrow?: string;
  categoryLabel?: string;
  categoryHref?: string;
  intro: string;
  faqItems?: FaqItem[];
  relatedTools?: RelatedTool[];
}

const {
  title,
  description,
  canonical,
  eyebrow = "Tool",
  categoryLabel = "Tools",
  categoryHref = "/",
  intro,
  faqItems = [],
  relatedTools = [],
} = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="tool-page">
    <section class="tool-hero">
      <div class="container">
        <div class="topline">
          <a href="/" class="logo">worowo</a>
        </div>
      </div>

      <div class="hero-divider"></div>

      <div class="container">
        <nav class="tool-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>&gt;</span>
          <a href={categoryHref}>{categoryLabel}</a>
          <span>&gt;</span>
          <span>{eyebrow}</span>
        </nav>

        <div class="hero-copy">
          <p class="eyebrow">{eyebrow}</p>
          <h1 class="page-title">Profit Margin Calculator</h1>
          <p class="page-summary tool-intro">{intro}</p>
        </div>
      </div>
    </section>

    <section class="tool-main">
      <div class="container">
        <div class="tool-grid">
          <slot name="form" />
          <slot name="results" />
        </div>
      </div>
    </section>

    {Astro.slots.has("content") && (
      <section class="tool-content">
        <div class="container content-grid">
          <slot name="content" />
        </div>
      </section>
    )}

    {(faqItems.length > 0 || Astro.slots.has("faq")) && (
      <section class="tool-faq">
        <div class="container">
          <h2 class="section-title">FAQ</h2>

          {faqItems.length > 0 && (
            <div class="faq-list">
              {faqItems.map((item) => (
                <details>
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>
          )}

          <slot name="faq" />
        </div>
      </section>
    )}

    {relatedTools.length > 0 && (
      <section class="tool-related">
        <div class="container">
          <h2 class="section-title">Related Tools</h2>

          <div class="related-grid">
            {relatedTools.map((tool) => (
              <a href={tool.href} class="related-card">
                <span class="related-name">{tool.name}</span>
                <span class="related-desc">{tool.desc}</span>
                <span class="related-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <slot />
  </main>
</BaseLayout>

<style>
  .tool-page {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  }

  .tool-hero {
    padding: 0 0 24px;
  }

  .tool-hero .topline {
    border-bottom: none;
    margin-bottom: 0;
  }

  .hero-divider {
    width: 100%;
    height: 1px;
    background: rgba(15, 23, 42, 0.08);
    margin: 0 0 18px;
  }

  .tool-breadcrumb {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 0 0 16px;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .tool-breadcrumb a:hover {
    color: var(--primary);
  }

  .tool-intro {
    max-width: 760px;
  }

  .page-title {
    margin: 0 0 10px;
    font-size: clamp(2.15rem, 3vw, 2.9rem);
    line-height: 1.06;
    letter-spacing: -0.035em;
  }

  .tool-main {
    padding: 8px 0 34px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: minmax(360px, 0.618fr) minmax(520px, 1fr);
    gap: 28px;
    align-items: stretch;
  }

  .content-grid,
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .tool-card,
  .content-card,
  .related-card,
  .faq-list details {
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 16px 40px -28px rgba(15, 23, 42, 0.25);
  }

  .content-card {
    padding: 24px;
  }

  .content-card h2,
  .section-title {
    margin: 0 0 10px;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .tool-content,
  .tool-faq,
  .tool-related {
    padding: 0 0 28px;
  }

  .content-card p,
  .content-card li {
    color: var(--text-soft);
    line-height: 1.8;
  }

  .content-card ul {
    margin: 14px 0 0;
    padding-left: 18px;
  }

  .faq-list {
    display: grid;
    gap: 16px;
    margin-top: 18px;
  }

  .faq-list details {
    padding: 18px 20px;
  }

  .faq-list summary {
    cursor: pointer;
    font-weight: 700;
    line-height: 1.6;
  }

  .faq-list p {
    margin: 14px 0 0;
    color: var(--text-soft);
    line-height: 1.85;
  }

  .related-card {
    position: relative;
    display: block;
    padding: 22px;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .related-card:hover {
    transform: translateY(-2px);
    border-color: var(--text);
  }

  .related-name {
    display: block;
    margin-bottom: 6px;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .related-desc {
    display: block;
    max-width: 32ch;
    color: var(--text-soft);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .related-arrow {
    position: absolute;
    top: 20px;
    right: 20px;
    color: var(--primary);
  }

  @media (max-width: 980px) {
    .tool-grid,
    .content-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .content-card {
      padding: 20px;
    }

    .page-title {
      font-size: clamp(1.9rem, 8vw, 2.35rem);
    }
  }
</style>
