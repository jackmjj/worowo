---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  category?: string;
  blankTemplateHref?: string;
  blankTemplateLabel?: string;
}

const {
  title,
  description,
  category = "Generator",
  blankTemplateHref,
  blankTemplateLabel = "View the blank template",
} = Astro.props;
---

<BaseLayout title={`${title} | Worowo`} description={description}>
  <main class="generator-page">
    <div class="generator-page-inner">
      <section class="generator-hero">
        <span class="generator-eyebrow">{category}</span>
        <h1 class="generator-title">{title}</h1>
        <p class="generator-description">{description}</p>

        {blankTemplateHref && (
          <div class="generator-hero-links">
            <a href={blankTemplateHref} class="generator-inline-link">
              {blankTemplateLabel}
            </a>
          </div>
        )}
      </section>

      <section class="generator-main">
        <div class="generator-form-column">
          <slot name="form" />
        </div>

        <div class="generator-preview-column">
          <slot name="preview" />
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .generator-page {
    background: #f8fafc;
  }

  .generator-page-inner {
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 42px 0 72px;
  }

  .generator-hero {
    margin-bottom: 28px;
  }

  .generator-eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #16a34a;
  }

  .generator-title {
    margin: 0 0 14px;
    font-size: clamp(34px, 4vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #0f172a;
  }

  .generator-description {
    max-width: 840px;
    margin: 0;
    font-size: 18px;
    line-height: 1.75;
    color: #475569;
  }

  .generator-hero-links {
    margin-top: 14px;
  }

  .generator-inline-link {
    display: inline-flex;
    align-items: center;
    color: #2563eb;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
  }

  .generator-main {
    display: grid;
    grid-template-columns: minmax(340px, 0.42fr) minmax(420px, 0.58fr);
    gap: 24px;
    align-items: start;
  }

  .generator-form-column,
  .generator-preview-column {
    min-width: 0;
  }

  @media (max-width: 980px) {
    .generator-main {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .generator-page-inner {
      width: min(1280px, calc(100% - 24px));
      padding: 28px 0 56px;
    }

    .generator-description {
      font-size: 16px;
    }
  }
</style>
