---
import BaseLayout from "./BaseLayout.astro";
import "../styles/printable-template.css";
import PrintablePreviewFrame from "../components/printable/PrintablePreviewFrame.astro";

interface Props {
  pageTitle: string;
  description: string;
  eyebrow?: string;
  previewTitle: string;
  previewDescription: string;
  printHref: string;
  backHref?: string;
  canonical?: string;
}

const {
  pageTitle,
  description,
  eyebrow = "Printable Template",
  previewTitle,
  previewDescription,
  printHref,
  backHref = "/printable-templates/",
  canonical,
} = Astro.props;
---

<BaseLayout title={`${pageTitle} | Worowo`} description={description} canonical={canonical}>
  <main class="printable-page-shell">
    <div class="page-wrap">
      <section class="hero">
        <span class="eyebrow">{eyebrow}</span>
        <h1 class="page-title">{pageTitle}</h1>
        <p class="page-description">{description}</p>
      </section>

      <div class="page-toolbar">
        <a class="btn btn-primary" href={printHref}>Open Full Printable Page</a>
        <a class="btn" href={backHref}>Back to Printable Templates</a>
      </div>

      <PrintablePreviewFrame title={previewTitle} description={previewDescription}>
        <slot name="preview" />
      </PrintablePreviewFrame>

      <slot name="note" />
    </div>
  </main>

  <style>
    .printable-page-shell {
      min-height: calc(100vh - 79px);
      background: var(--page-bg);
    }
  </style>
</BaseLayout>
