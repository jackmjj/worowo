---
interface Props {
  name?: string;
}

const { name = "grid" } = Astro.props;

const common = {
  width: 20,
  height: 20,
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.8",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
};
---

{
  name === "invoice" && (
    <svg {...common}>
      <path d="M7 3h8l4 4v14H7z" />
      <path d="M15 3v4h4" />
      <path d="M10 12h6" />
      <path d="M10 16h6" />
      <path d="M10 8h2" />
    </svg>
  )
}

{
  name === "quote" && (
    <svg {...common}>
      <path d="M8 4h11v16H5V7z" />
      <path d="M8 4v3H5" />
      <path d="M9 11h6" />
      <path d="M9 15h6" />
      <path d="M9 8h2" />
    </svg>
  )
}

{
  name === "receipt" && (
    <svg {...common}>
      <path d="M7 3h10v18l-2-1-2 1-2-1-2 1-2-1V3z" />
      <path d="M9 8h6" />
      <path d="M9 12h6" />
      <path d="M9 16h4" />
    </svg>
  )
}

{
  name === "packing" && (
    <svg {...common}>
      <path d="M3 7l9-4 9 4-9 4z" />
      <path d="M3 7v10l9 4 9-4V7" />
      <path d="M12 11v10" />
    </svg>
  )
}

{
  name === "delivery" && (
    <svg {...common}>
      <path d="M3 7h11v8H3z" />
      <path d="M14 10h3l3 3v2h-6z" />
      <circle cx="8" cy="18" r="2" />
      <circle cx="18" cy="18" r="2" />
    </svg>
  )
}

{
  name === "calendar" && (
    <svg {...common}>
      <rect x="3" y="5" width="18" height="16" rx="2" />
      <path d="M16 3v4" />
      <path d="M8 3v4" />
      <path d="M3 10h18" />
    </svg>
  )
}

{
  name === "timesheet" && (
    <svg {...common}>
      <circle cx="12" cy="13" r="8" />
      <path d="M12 9v4l3 2" />
      <path d="M9 3h6" />
    </svg>
  )
}

{
  name === "cash" && (
    <svg {...common}>
      <rect x="3" y="6" width="18" height="12" rx="2" />
      <circle cx="12" cy="12" r="3" />
      <path d="M7 10h.01" />
      <path d="M17 14h.01" />
    </svg>
  )
}

{
  name === "work" && (
    <svg {...common}>
      <path d="M10 3h4l1 3h4v14H5V6h4z" />
      <path d="M9 6h6" />
      <path d="M12 10v6" />
      <path d="M9 13h6" />
    </svg>
  )
}

{
  name === "calculator" && (
    <svg {...common}>
      <rect x="5" y="3" width="14" height="18" rx="2" />
      <path d="M8 7h8" />
      <path d="M8 11h2" />
      <path d="M14 11h2" />
      <path d="M8 15h2" />
      <path d="M14 15h2" />
      <path d="M8 19h8" />
    </svg>
  )
}

{
  name === "profit" && (
    <svg {...common}>
      <path d="M4 18h16" />
      <path d="M7 15l3-4 3 2 4-6" />
      <path d="M16 7h3v3" />
    </svg>
  )
}

{
  name === "tax" && (
    <svg {...common}>
      <path d="M7 3h8l4 4v14H7z" />
      <path d="M15 3v4h4" />
      <path d="M10 11h4" />
      <path d="M10 15h4" />
    </svg>
  )
}

{
  name === "template" && (
    <svg {...common}>
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <path d="M8 8h8" />
      <path d="M8 12h8" />
      <path d="M8 16h5" />
    </svg>
  )
}

{
  ![
    "invoice",
    "quote",
    "receipt",
    "packing",
    "delivery",
    "calendar",
    "timesheet",
    "cash",
    "work",
    "calculator",
    "profit",
    "tax",
    "template",
  ].includes(name) && (
    <svg {...common}>
      <rect x="4" y="4" width="7" height="7" rx="1.5" />
      <rect x="13" y="4" width="7" height="7" rx="1.5" />
      <rect x="4" y="13" width="7" height="7" rx="1.5" />
      <rect x="13" y="13" width="7" height="7" rx="1.5" />
    </svg>
  )
}
